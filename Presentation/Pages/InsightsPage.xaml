<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Rok.Pages.InsightsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Rok.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:controls="using:CommunityToolkit.WinUI.Controls" xmlns:models="using:Rok.Application.Features.Insights.Query" xmlns:viewmodels="using:Rok.ViewModels.Insights"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
        </Style>
    </Page.Resources>

    <ScrollViewer>

        <StackPanel Padding="24" Spacing="24">

            <!-- Hero section -->
            <TextBlock x:Uid="Insights_HeroTitle"  Text="🎨 Ton mois en musique" Style="{StaticResource HeaderTextBlockStyle}" />

            <controls:WrapPanel Orientation="Horizontal" HorizontalSpacing="12" VerticalSpacing="12">
                
                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Insights_TotalPlayDuration"  Text="Temps total d'écoute" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}">
                            <Run Text="{x:Bind ViewModel.Insights.PlayDuration, Converter={StaticResource SecondsToReadableConverter}}" />
                            <Run Text="{x:Bind ViewModel.PlayDurationDiffText}" Foreground="{x:Bind ViewModel.Insights.DifferencePlayDuration, Converter={StaticResource IntToColorConverter}, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Insights_TotalSessions"  Text="Nombre de sessions" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}">
                            <Run Text="{x:Bind ViewModel.Insights.SessionCount}" />
                            <Run Text="{x:Bind ViewModel.SessionDiffText}" Foreground="{x:Bind ViewModel.Insights.DifferenceSessionCount, Converter={StaticResource IntToColorConverter}, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Insights_TotalTracks"  Text="Titres différents écoutés" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}">
                            <Run Text="{x:Bind ViewModel.Insights.TracksPlayed}" />
                            <Run Text="{x:Bind ViewModel.TracksPlayedDiffText}" Foreground="{x:Bind ViewModel.Insights.DifferenceTracksPlayed, Converter={StaticResource IntToColorConverter}, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Insights_TotalArtists"  Text="Artistes différents écoutés" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}">
                            <Run Text="{x:Bind ViewModel.Insights.ArtistsPlayed}" />
                            <Run Text="{x:Bind ViewModel.ArtistsPlayedDiffText}" Foreground="{x:Bind ViewModel.Insights.DifferenceArtistsPlayed, Converter={StaticResource IntToColorConverter}, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Insights_TotalAlbums"  Text="Albums différents écoutés" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}">
                            <Run Text="{x:Bind ViewModel.Insights.AlbumsPlayed}" />
                            <Run Text="{x:Bind ViewModel.AlbumsPlayedDiffText}" Foreground="{x:Bind ViewModel.Insights.DifferenceAlbumsPlayed, Converter={StaticResource IntToColorConverter}, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="Insights_TotalGenres"  Text="Genres différents écoutés" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}">
                            <Run Text="{x:Bind ViewModel.Insights.GenresPlayed}" />
                            <Run Text="{x:Bind ViewModel.GenresPlayedDiffText}" Foreground="{x:Bind ViewModel.Insights.DifferenceGenresPlayed, Converter={StaticResource IntToColorConverter}, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </controls:WrapPanel>

            <TextBlock x:Uid="Insights_HotListeningTimes"  Text="🔥 Quand tu écoutes le plus" Style="{StaticResource HeaderTextBlockStyle}" />
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel Spacing="8">

                    <!-- Hour axis labels: one label every 4 hours (0h, 4h, 8h, ...) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ItemsRepeater Grid.Column="1" ItemsSource="{x:Bind ViewModel.HourAxisLabels, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="2"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:HourLabelViewModel">
                                    <TextBlock Text="{x:Bind Label}" Width="20" FontSize="9" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>

                    <!-- One row per day of week -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.HeatmapRows, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:HeatmapRowViewModel">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind DayLabel}" VerticalAlignment="Center" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <ItemsRepeater Grid.Column="1" ItemsSource="{x:Bind Cells}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Orientation="Horizontal" Spacing="2"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="viewmodels:HeatmapCellViewModel">
                                                <Grid Width="20" Height="20">
                                                    <Border CornerRadius="3" Background="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                                    <Border CornerRadius="3" Background="{ThemeResource BrandAccentBrush}" Opacity="{x:Bind Intensity}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Border>

            <TextBlock Text="🎧 Tes sessions d'écoute" Style="{StaticResource HeaderTextBlockStyle}" />
            <!--<StackPanel Spacing="16">

                <TextBlock Text="Tes sessions d'écoute"
                   Style="{StaticResource TitleMedium}" />

                <local:StatCard Title="Durée moyenne"
                        Value="{x:Bind ViewModel.AverageSessionDuration}" />

                <local:StatCard Title="Session la plus longue"
                        Value="{x:Bind ViewModel.LongestSession}" />

                <TextBlock Text="Titres qui ouvrent tes sessions"
                   Style="{StaticResource Subtitle}" />

                <local:TrackListControl Items="{x:Bind ViewModel.SessionStartTracks}" />

                <TextBlock Text="Titres qui terminent tes sessions"
                   Style="{StaticResource Subtitle}" />

                <local:TrackListControl Items="{x:Bind ViewModel.SessionEndTracks}" />

            </StackPanel>-->

            <TextBlock x:Uid="Insights_ImportantTracks"  Text="🏆 Tes titres les plus importants" Style="{StaticResource HeaderTextBlockStyle}" />
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel Spacing="20">

                    <TextBlock x:Uid="Insights_TopTracks"  Text="Titres" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled" ZoomMode="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Insights.TopTracks}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="12"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:TrackInsightDto">
                                    <Border Width="200" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10" Padding="14">
                                        <StackPanel Spacing="10">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{x:Bind Title}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind ArtistName}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Spacing="3">
                                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                                                    <Run Text="{x:Bind PlayCount}" FontWeight="SemiBold"/>
                                                    <Run Text=" écoutes ce mois-ci"/>
                                                </TextBlock>
                                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{x:Bind LongSessionCount}"/>
                                                    <Run Text=" sessions longues"/>
                                                </TextBlock>
                                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="Pic : "/>
                                                    <Run Text="{x:Bind PeakHourRange}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>

                    <TextBlock x:Uid="Insights_TopAlbums" Text="Albums" Style="{ThemeResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled" ZoomMode="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Insights.TopAlbums}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="12"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:AlbumInsightDto">
                                    <Border Width="200" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="10" Padding="14">
                                        <StackPanel Spacing="10">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{x:Bind Title}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind ArtistName}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Spacing="3">
                                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                                                    <Run Text="{x:Bind PlayCount}" FontWeight="SemiBold"/>
                                                    <Run Text=" écoutes ce mois-ci"/>
                                                </TextBlock>
                                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{x:Bind LongSessionCount}"/>
                                                    <Run Text=" sessions longues"/>
                                                </TextBlock>
                                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="Pic : "/>
                                                    <Run Text="{x:Bind PeakHourRange}"/>
                                                </TextBlock>
                                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="Dominant : "/>
                                                    <Run Text="{x:Bind DominantTitle}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>

                </StackPanel>
            </Border>

            <TextBlock x:Uid="InsightsPage_ListeningProfileHeader"  Text="🧬 Ton profil d'écoute" Style="{StaticResource HeaderTextBlockStyle}" />

            <StackPanel Orientation="Horizontal" Spacing="24">
                <Border Style="{StaticResource MetricCardStyle}" Width="400" MaxWidth="400" HorizontalAlignment="Left">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.ListeningProfileCard.Icon, Mode=OneWay}" FontSize="28" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.ListeningProfileCard.Label, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.ListeningProfileCard.Description, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" TextWrapping="Wrap" Opacity="0.8"/>
                        <StackPanel Spacing="4">
                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                            <Run Text="• Skip rate : "/> 
                            <Run Text="{x:Bind ViewModel.ListeningProfileCard.SkipRateText, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                            <Run Text="• Replay rate : "/>
                            <Run Text="{x:Bind ViewModel.ListeningProfileCard.ReplayRateText, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                            <Run Text="• Diversité : "/>
                            <Run Text="{x:Bind ViewModel.ListeningProfileCard.DiversityText, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Width="400" MaxWidth="400" HorizontalAlignment="Left">
                    <StackPanel Spacing="16">
                        <TextBlock x:Uid="Insights_TopGenres"  Text="Top Genres" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Insights.TopGenres, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="16"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:GenreInsightDto">
                                    <StackPanel Spacing="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind RankText}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind GenreName}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind PlayPercentageText}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource BrandAccentBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ProgressBar Value="{x:Bind PlayPercentage}" Maximum="100" Height="6"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>


            <TextBlock x:Uid="Insights_BadgesHeader"  Text="🥇 Tes badges" Style="{StaticResource HeaderTextBlockStyle}" />
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Badges, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinColumnSpacing="12" MinRowSpacing="12" MinItemWidth="260" ItemsJustification="Start"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:BadgeViewModel">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="48" Height="48"
                                        CornerRadius="24"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Icon}"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name}"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind Description}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>        
    </ScrollViewer>
</Page>
