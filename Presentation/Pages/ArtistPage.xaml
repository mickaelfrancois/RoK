<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Rok.Pages.ArtistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Rok.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:common="using:Rok.Commons"
      xmlns:tracks="using:Rok.ViewModels.Track"
      xmlns:albums="using:Rok.ViewModels.Album"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="headerRow" Height="{StaticResource HeaderRowHeight}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.Background>
            <SolidColorBrush Color="{ThemeResource CardBackgroundFillColorDefault}" Opacity="{StaticResource HeaderBackgroundOpacity}" />
        </Grid.Background>

        <Image x:Name="backdrop" Grid.RowSpan="2" Style="{StaticResource HeaderBackdropStyle}" Source="{x:Bind ViewModel.Backdrop,Mode=OneWay}" Stretch="UniformToFill" IsHitTestVisible="False" />

        <!-- Header -->
        <Grid Padding="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="pictureColumn" Width="{StaticResource HeaderPictureColumnWidth}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Style="{StaticResource HeaderPictureGridStyle}">
                <common:PictureControl x:Name="artistPicture" Style="{StaticResource HeaderPictureStyle}"  Cover="{x:Bind ViewModel.Picture, Mode=OneWay}" />
                <Button x:Uid="selectPicture" Style="{StaticResource HeaderPictureSelectButtonStyle}" Command="{x:Bind ViewModel.SelectPictureCommand}" />
            </Grid>

            <RelativePanel x:Name="headerPanel" Grid.Column="1" Margin="6,0,0,0">
                <TextBlock x:Name="artistName" Style="{StaticResource HeaderTitleTextStyle}" Text="{x:Bind ViewModel.Artist.Name, Mode=OneWay}" />

                <Button x:Name="buttonCountry" Style="{StaticResource ButtonTextBlockStyle}" RelativePanel.RightOf="artistName" RelativePanel.AlignVerticalCenterWith="artistName" Visibility="{x:Bind ViewModel.Artist.CountryCode, Converter={StaticResource StringToVisibilityConverter}}" Margin="6,0,0,0"                         ToolTipService.ToolTip="{x:Bind ViewModel.Artist.CountryName}">
                    <Image Source="{x:Bind ViewModel.Artist.CountryCode, Converter={StaticResource CountryCodeToImageSourceConverter}}" Height="{StaticResource CountryFlagHeight}"/>
                </Button>

                <TextBlock x:Name="year" RelativePanel.RightOf="buttonCountry" RelativePanel.AlignVerticalCenterWith="buttonCountry" Text="{x:Bind ViewModel.ActiveYears}" Style="{StaticResource HeaderYearTextStyle}"  />
                <HyperlinkButton x:Name="genreName" Style="{StaticResource HeaderHyperlinkStyle}"  Content="{x:Bind ViewModel.Artist.GenreName}" RelativePanel.Below="artistName" Command="{x:Bind ViewModel.GenreOpenCommand}" />

                <TextBlock x:Name="panelExtendedInfo" Style="{StaticResource HeaderTextStyle}" RelativePanel.RightOf="genreName" RelativePanel.AlignBottomWith="genreName" Margin="6,0,0,0" >
                    <Run Text="🔹" />
                    <Run Text="{x:Bind ViewModel.SubTitle}" />
                </TextBlock>

                <CommandBar x:Name="panelNetwork" Style="{StaticResource HeaderCommandBarStyle}" RelativePanel.Below="tagsContainer" RelativePanel.AlignLeftWith="artistName">
                    <common:SocialNetworkAppBarButton x:Uid="artistViewWebSite" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="{x:Bind ViewModel.Artist.OfficialSiteUrl}" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.OfficialSiteUrl, Mode=OneWay}" IconFill="{StaticResource WebsiteBrush}" IconData="{StaticResource BrandIconWebsite}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewLastFm" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Last.FM" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.LastFmUrl, Mode=OneWay}" IconFill="{StaticResource LastFmBrush}" IconData="{StaticResource BrandIconLastFm}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewWikipedia" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Wikipedia" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.WikipediaUrl, Mode=OneWay}" IconFill="{StaticResource WikipediaBrush}" IconData="{StaticResource BrandIconWikipedia}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewFacebook" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Facebook" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.FacebookUrl, Mode=OneWay}" IconFill="{StaticResource FacebookBrush}" IconData="{StaticResource BrandIconFacebook}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewInstagram" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Instagram" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.InstagramUrl, Mode=OneWay}" IconFill="{StaticResource InstagramBrush}" IconData="{StaticResource BrandIconInstagram}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewTwitter" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="X" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.TwitterUrl, Mode=OneWay}" IconFill="{StaticResource TwitterBrush}" IconData="{StaticResource BrandIconTwitter}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewThreads" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Threads" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.ThreadsUrl, Mode=OneWay}" IconFill="{StaticResource ThreadsBrush}" IconData="{StaticResource BrandIconThreads}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewTikTok" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Tiktok" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.TiktokUrl, Mode=OneWay}" IconFill="{StaticResource TiktokBrush}" IconData="{StaticResource BrandIconTikTok}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewYoutube" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Youtube" Command="{x:Bind ViewModel.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.YoutubeUrl, Mode=OneWay}" IconFill="{StaticResource YoutubeBrush}" IconData="{StaticResource BrandIconYoutube}" />
                </CommandBar>

                <StackPanel x:Name="tagsContainer" RelativePanel.Below="panelExtendedInfo" RelativePanel.AlignLeftWith="artistName" Orientation="Horizontal" Spacing="0" Margin="0">
                    <controls:TokenizingTextBox x:Uid="TagsBox" x:Name="TagsBox" Style="{StaticResource TokenizingTextBoxStyle}"  ItemsSource="{x:Bind ViewModel.Tags, Mode=OneWay}" SuggestedItemsSource="{x:Bind ViewModel.SuggestedTags, Mode=OneWay}">
                        <controls:TokenizingTextBox.Resources>
                            <Style TargetType="controls:TokenizingTextBoxItem" BasedOn="{StaticResource TokenizingTextBoxItemStyle}" />
                        </controls:TokenizingTextBox.Resources>
                    </controls:TokenizingTextBox>
                </StackPanel>

                <CommandBar  RelativePanel.AlignBottomWithPanel="True" RelativePanel.AlignLeftWith="artistName" Style="{StaticResource HeaderCommandBarStyle}">
                    <AppBarButton x:Uid="artistViewListen" Style="{StaticResource ListenAppBarButtonStyle}" Command="{x:Bind ViewModel.ListenCommand}" />
                    <AppBarToggleButton x:Uid="artistViewLike" x:Name="artistAppBarLike" Style="{StaticResource HeaderLikeButtonStyle}" IsChecked="{x:Bind ViewModel.IsFavorite, Mode=OneWay}" Command="{x:Bind ViewModel.ArtistFavoriteCommand}" />
                    <AppBarButton x:Uid="artistViewBiography" Style="{StaticResource HeaderGenericButtonStyle}" Icon="Library" Command="{x:Bind ViewModel.OpenBiographyCommand}" Visibility="{x:Bind ViewModel.Artist.Biography, Converter={StaticResource StringToVisibilityConverter}}" />
                    <AppBarButton x:Uid="artistViewPlaylist" Style="{StaticResource HeaderGenericButtonStyle}" Icon="Add" Visibility="Collapsed" IsEnabled="False" />
                    <AppBarButton x:Uid="albumViewPlaylist" Style="{StaticResource HeaderGenericButtonStyle}" Icon="Add">
                        <AppBarButton.Flyout>
                            <MenuFlyout x:Name="albumPlaylistFlyout" common:MenuFlyoutExtensions.PlaylistMenuService="{x:Bind ViewModel.PlaylistMenuService}" common:MenuFlyoutExtensions.ArtistId="{x:Bind ViewModel.Artist.Id}" common:MenuFlyoutExtensions.FlattenPlaylistMenu="True" />
                        </AppBarButton.Flyout>
                    </AppBarButton>
                    <AppBarButton x:Uid="artistViewEdit" Style="{StaticResource HeaderGenericButtonStyle}" Icon="Edit" Visibility="Collapsed" IsEnabled="False" />
                </CommandBar>
            </RelativePanel>
        </Grid>


        <!-- Content -->
        <Grid Grid.Row="1" Style="{StaticResource FileGridStyle}">
            <Pivot>
                <!-- Albums -->
                <PivotItem x:Uid="artistViewTabAlbums">
                    <common:GridViewExtended x:Name="grid" ItemsPanel="{StaticResource GridPanelTemplate}" ItemsSource="{x:Bind ViewModel.Albums}" ContainerContentChanging="grid_ContainerContentChanging" Margin="0" ScrollViewer.VerticalScrollMode="Enabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="albums:AlbumViewModel">
                                <Grid Style="{StaticResource MainGridCoverStyle}">
                                    <Border CornerRadius="{StaticResource CornerRadiusMediumValue}">
                                        <common:PictureControl Style="{StaticResource PictureCoverStyle}" Cover="{x:Bind Picture, Mode=OneWay}" x:Phase="2" PlayButtonVisibility="Visible" Command="{x:Bind ListenCommand}" />
                                    </Border>

                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Vertical" Spacing="{StaticResource SpacingXSmall}" Margin="0,8,8,0">
                                        <common:BadgeControl x:Uid="badgeLive" Visibility="{x:Bind IsLive, Converter={StaticResource BoolToVisibilityConverter}}" BadgeBackground="{StaticResource BadgeLiveBrush}"/>
                                        <common:BadgeControl x:Uid="badgeBestof" Visibility="{x:Bind IsBestOf, Converter={StaticResource BoolToVisibilityConverter}}" BadgeBackground="{StaticResource BadgeBestOfBrush}" />
                                        <common:BadgeControl x:Uid="badgeCompilation" Visibility="{x:Bind IsCompilation, Converter={StaticResource BoolToVisibilityConverter}}" BadgeBackground="{StaticResource BadgeCompilationBrush}" />
                                        <common:BadgeControl x:Uid="badgeNew" Visibility="{x:Bind ShowNewBadge, Converter={StaticResource BoolToVisibilityConverter}}" BadgeBackground="{StaticResource BadgeNewBrush}" />
                                    </StackPanel>

                                    <Grid x:Name="gridBottom" Style="{StaticResource GridCoverBottomStyle}" Background="{x:Bind DominantColor, Converter={StaticResource ColorToGradientBrushConverter}, Mode=OneWay}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="{StaticResource GridBottomFirstRowHeight}" />
                                            <RowDefinition Height="{StaticResource GridBottomSecondRowHeight}" />
                                        </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="{StaticResource FavoriteButtonColumnWidth}" />
                                        </Grid.ColumnDefinitions>

                                        <HyperlinkButton Content="{x:Bind Album.Name}" x:Phase="0" Command="{x:Bind AlbumOpenCommand}" Style="{StaticResource GridCoverButtonStyle}" />
                                        <TextBlock x:Name="subTitle" Grid.Row="1" Style="{StaticResource GridCoverBottomSecondLineStyle}" Margin="4,6,0,0" Text="{x:Bind SubTitle, Mode=OneWay}" Opacity="1" x:Phase="1" />

                                        <common:AnimatedButton x:Name="favoriteButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0" Opacity="{x:Bind IsFavorite, Converter={StaticResource BoolToOpacityConverter}, Mode=OneWay}" Icon="{StaticResource HeartPath}" Color="{x:Bind IsFavorite, Converter={StaticResource FavoriteToColorConverter}, Mode=OneWay}" Command="{x:Bind AlbumFavoriteCommand}" CommandParameter="{x:Bind IsFavorite, Converter={StaticResource BoolToInvertBoolConverter}, Mode=OneWay}" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </common:GridViewExtended>
                </PivotItem>

                <!-- Tracks-->
                <PivotItem x:Uid="artistViewTabTracks">
                    <Grid x:Name="tracks" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{StaticResource GridHeaderTracksHeight}" />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <!-- Grid headers -->
                        <Grid Style="{StaticResource HeaderTracksGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{StaticResource GridHeaderTracksTitleColumnWidth}" />
                                <ColumnDefinition Width="{StaticResource GridHeaderTracksAlbumColumnWidth}" />
                                <ColumnDefinition Width="{StaticResource GridHeaderTracksScoreColumnWidth}" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Uid="gridHeaderTitle" Grid.Column="0" Style="{StaticResource GridHeaderTracksTextBlockStyle}" />
                            <TextBlock x:Uid="gridHeaderAlbum" Grid.Column="1" Style="{StaticResource GridHeaderTracksTextBlockStyle}" />
                            <TextBlock x:Uid="gridHeaderScore" Grid.Column="2" Style="{StaticResource GridHeaderTracksTextBlockStyle}" />
                        </Grid>

                        <ListView x:Name="tracksList" Grid.Row="1" ContainerContentChanging="tracksList_ContainerContentChanging" ItemsSource="{x:Bind ViewModel.Tracks}" ItemContainerStyle="{StaticResource TracksListViewItemStyle}" SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="tracks:TrackViewModel">
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{StaticResource GridHeaderTracksTitleColumnWidth}" />
                                            <ColumnDefinition Width="{StaticResource GridHeaderTracksAlbumColumnWidth}" />
                                            <ColumnDefinition Width="{StaticResource GridHeaderTracksScoreColumnWidth}" />
                                        </Grid.ColumnDefinitions>

                                        <Grid.ContextFlyout>
                                            <MenuFlyout ShowMode="TransientWithDismissOnPointerMoveAway" common:MenuFlyoutExtensions.PlaylistMenuService="{x:Bind PlaylistMenuService}" common:MenuFlyoutExtensions.TrackId="{x:Bind Track.Id}">
                                                <MenuFlyoutItem x:Uid="trackFlyoutListen" Icon="Play" Command="{x:Bind ListenCommand}" CommandParameter="{x:Bind}" />
                                                <MenuFlyoutItem x:Uid="trackFlyoutArtist" Icon="People" Command="{x:Bind ArtistOpenCommand}" Visibility="Collapsed" />
                                                <MenuFlyoutItem x:Uid="trackFlyoutAlbum" Command="{x:Bind AlbumOpenCommand}" >
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xe93c;" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem x:Uid="trackFlyoutTrack" Icon="Audio" Command="{x:Bind TrackOpenCommand}"/>
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem x:Uid="trackFlyoutLyrics" Command="{x:Bind LyricsOpenCommand}" Visibility="{x:Bind LyricsExists, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE90B;" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock x:Name="RowIndexText" Style="{StaticResource GridTracksRowIndexTextBlockStyle}" />
                                            <HyperlinkButton Style="{StaticResource GridTracksTitleHyperlinkButtonStyle}" Command="{x:Bind ListenCommand}" CommandParameter="{x:Bind}" />
                                            <HyperlinkButton x:Uid="lyricsTag" Visibility="{x:Bind LyricsExists, Converter={StaticResource BoolToVisibilityConverter}}" Style="{StaticResource GridTracksLyricsHyperlinkButtonStyle}" Command="{x:Bind LyricsOpenCommand}" />
                                        </StackPanel>

                                        <HyperlinkButton Grid.Column="1" Style="{StaticResource GridTracksArtistHyperlinkButtonStyle}" Command="{x:Bind ArtistOpenCommand}" />
                                        <common:RatingControlLightControl Grid.Column="2" Style="{StaticResource GridTracksScoreStyle}" RatingValue="{x:Bind Score, Mode=TwoWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>
            </Pivot>
        </Grid>
    </Grid>
</Page>
