<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="ApplicationTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBrand}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeading}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>


    <Style x:Key="HorizontalPlayerBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PlayerSurfaceBrush}" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>


    <DataTemplate x:Key="SearchSuggestionItemTemplate">
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0"
                      FontSize="16"
                      Margin="0,0,12,0"
                      VerticalAlignment="Center"
                      Glyph="{Binding IconGlyph}" />
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding Type}"
                           FontSize="{StaticResource FontSizeXSmall}"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>
    </DataTemplate>

    <Style x:Key="NavigationSearchBoxStyle" TargetType="AutoSuggestBox" BasedOn="{StaticResource DefaultAutoSuggestBoxStyle}">
        <Setter Property="QueryIcon" Value="Find" />
        <Setter Property="TextMemberPath" Value="Name" />
        <Setter Property="Width" Value="{StaticResource SearchBoxWidth}" />
        <Setter Property="MaxWidth" Value="{StaticResource SearchBoxWidth}" />
        <Setter Property="MinWidth" Value="{StaticResource SearchBoxWidth}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMediumValue}" />
        <Setter Property="ItemTemplate" Value="{StaticResource SearchSuggestionItemTemplate}" />
    </Style>


    <Style x:Key="PaneHeaderSeparatorStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource NavigationSeparatorThickness}" />
        <Setter Property="Height" Value="{StaticResource AppLogoSize}" />
        <Setter Property="Margin" Value="8,0,8,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="Opacity" Value="{StaticResource NavigationSeparatorOpacity}" />
    </Style>

    <Style x:Key="MainNavigationViewStyle" TargetType="NavigationView">
        <Setter Property="Background" Value="{ThemeResource NavigationViewExpandedPaneBackground}" />
        <Setter Property="IsSettingsVisible" Value="True" />
        <Setter Property="IsBackButtonVisible" Value="Auto" />
        <Setter Property="AlwaysShowHeader" Value="False" />
        <Setter Property="PaneDisplayMode" Value="Top" />
        <Setter Property="ExpandedModeThresholdWidth" Value="{StaticResource NavigationExpandedThreshold}" />
        <Setter Property="SelectionFollowsFocus" Value="Enabled" />
        <Setter Property="IsTabStop" Value="False" />
    </Style>

    
    <!-- Buttons -->

    <Style x:Key="ListenAppBarButtonCompactStyle"
           TargetType="AppBarButton">
        <Setter Property="Foreground" Value="{ThemeResource OnSurfacePrimaryBrush}" />
        <Setter Property="Icon" Value="Play" />
        <Setter Property="Background" Value="{ThemeResource BrandPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSmallValue}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="30" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Width" Value="100" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="AppBarButton">
                    <Grid x:Name="Root"
                          Height="{TemplateBinding Height}"
                          VerticalAlignment="Center"
                          Background="Transparent">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                Height="{TemplateBinding Height}">
                            <StackPanel x:Name="ContentPanel" Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ContentPresenter x:Name="IconPresenter" Content="{TemplateBinding Icon}" VerticalAlignment="Center" />
                                <TextBlock x:Name="LabelText"
                                           Text="{TemplateBinding Label}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}" />
                            </StackPanel>
                        </Border>

                        <VisualStateManager.VisualStateGroups>

                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource BrandPrimaryHoverBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource BrandPrimaryPressedBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.45" Duration="0:0:0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Focused">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource OnSurfacePrimaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="BorderThickness">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="1" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerFocused" />
                                <VisualState x:Name="Unfocused" />
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="DisplayModeStates">
                                <VisualState x:Name="FullSize" />
                                <VisualState x:Name="Compact">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LabelText" Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Collapsed" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>

                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppBarButtonCompactStyle"
           TargetType="AppBarButton">
        <Setter Property="Foreground" Value="{ThemeResource OnNeutralSurfacePrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="6,0,0,0" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSmallValue}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Width" Value="auto" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="AppBarButton">
                    <Grid x:Name="Root" Height="{TemplateBinding Height}" VerticalAlignment="Center" Background="Transparent">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                Height="{TemplateBinding Height}">
                            <StackPanel x:Name="ContentPanel" Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center" HorizontalAlignment="Center">

                                <ContentPresenter x:Name="IconGlyph"
                                                  Content="{TemplateBinding Icon}"
                                                  FontSize="18"
                                                  Foreground="{TemplateBinding Foreground}" />

                                <TextBlock x:Name="LabelText"
                                           Text="{TemplateBinding Label}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}" />
                            </StackPanel>
                        </Border>

                        <VisualStateManager.VisualStateGroups>

                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource BrandPrimaryHoverBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LabelText" Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource OnSurfacePrimaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="IconGlyph" Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource OnSurfacePrimaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg"
                                       Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource OnSurfacePrimaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.45" Duration="0:0:0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Focused">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource OnNeutralSurfacePrimaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bg" Storyboard.TargetProperty="BorderThickness">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="1" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerFocused" />
                                <VisualState x:Name="Unfocused" />
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="DisplayModeStates">
                                <VisualState x:Name="FullSize" />
                                <VisualState x:Name="Compact">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LabelText" Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Collapsed" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>

                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    

    <!-- CommandBar SplitButton -->
    
    <Style x:Key="CommandBarSplitButtonPanelStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="{StaticResource SpacingSmall}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CommandBarSplitButtonIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CommandBarSplitButtonValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MaxWidth" Value="140" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="CommandBarSplitButtonLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    
    <!-- CommandBar stat info -->
    
    <Style x:Key="CommandBarStatInfoPanelStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="{StaticResource SpacingXSmall}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CommandBarStatInfoIconStyle" TargetType="FontIcon">
        <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CommandBarStatInfoSeparatorStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="Text" Value="•" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0.4" />
    </Style>

    <Style x:Key="CommandBarStatInfoTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>


    <!-- List pages-->
    
    <Style x:Key="HeaderCommandBarListStyle" TargetType="CommandBar">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="IsSticky" Value="True"/>
        <Setter Property="DefaultLabelPosition" Value="Right"/>
    </Style>

    <Style x:Key="GridListStyle" TargetType="Grid">
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBarBorderThemeBrush}" />
        <Setter Property="Background" Value="{StaticResource ContentListBackgroundBrush}" />
    </Style>

    <Style x:Key="ListModeGridViewItemStyle" TargetType="GridViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,0,0,1" />
    </Style>

    <ItemsPanelTemplate x:Key="GridPanelTemplate">
        <ItemsWrapGrid Orientation="Horizontal" ItemHeight="{StaticResource GridItemHeight}" ItemWidth="{StaticResource GridItemWidth}" Margin="0,0,2,2" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="VerticalListPanelTemplate">
        <ItemsStackPanel Orientation="Vertical" />
    </ItemsPanelTemplate>

    <!-- SemanticZoom — Group header -->
    <Style x:Key="GroupHeaderCountBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SystemFillColorNeutralBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMediumValue}" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <Style x:Key="GroupHeaderCountTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0.7" />
    </Style>

    <Style x:Key="GroupHeaderListenButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="10,0,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSmallValue}" />
    </Style>

    <!-- SemanticZoom — ZoomedOut view -->
    <DataTemplate x:Key="SemanticZoomOutGroupItemDataTemplate">
        <TextBlock HorizontalAlignment="Center" Width="200" Text="{Binding Group.Title}" />
    </DataTemplate>

    <ItemsPanelTemplate x:Key="GroupVariableWrapPanelTemplate">
        <VariableSizedWrapGrid Orientation="Vertical" Margin="0,0,80,0" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="SemanticZoomOutGroupPanelTemplate">
        <WrapGrid Orientation="Horizontal" VerticalChildrenAlignment="Center" MaximumRowsOrColumns="4" />
    </ItemsPanelTemplate>

</ResourceDictionary>
