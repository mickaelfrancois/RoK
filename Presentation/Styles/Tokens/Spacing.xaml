<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="SpacingXSmall">4</x:Double>
    <x:Double x:Key="SpacingSmall">8</x:Double>
    <x:Double x:Key="SpacingMedium">16</x:Double>
    <x:Double x:Key="SpacingLarge">24</x:Double>

    <x:Double x:Key="CoverSize">300</x:Double>
    <x:Double x:Key="CoverOverlayHeight">60</x:Double>
    <x:Double x:Key="CornerRadiusSmall">4</x:Double>
    <x:Double x:Key="CornerRadiusMedium">10</x:Double>

    <CornerRadius x:Key="CornerRadiusSmallValue">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMediumValue">10</CornerRadius>

    <x:Double x:Key="AppLogoSize">25</x:Double>

    <x:Double x:Key="SearchBoxWidth">400</x:Double>
    <x:Double x:Key="NavigationExpandedThreshold">500</x:Double>
    <x:Double x:Key="NavigationSeparatorThickness">1</x:Double>
    <x:Double x:Key="NavigationSeparatorOpacity">0.6</x:Double>

    <!-- List pages -->
    <GridLength x:Key="HeaderListRowHeight">45</GridLength>
    <GridLength x:Key="GridBottomFirstRowHeight">30</GridLength>
    <GridLength x:Key="GridBottomSecondRowHeight">30</GridLength>
    
    <!-- File page -->
    <GridLength x:Key="HeaderPictureColumnWidth">180</GridLength>
    <GridLength x:Key="HeaderRowHeight">200</GridLength>
    <x:Double x:Key="CountryFlagHeight">10</x:Double>

    <!-- Tracks list -->
    <GridLength x:Key="GridHeaderTracksTitleColumnWidth">350</GridLength>
    <GridLength x:Key="GridHeaderTracksAlbumColumnWidth">250</GridLength>
    <GridLength x:Key="GridHeaderTracksArtistColumnWidth">350</GridLength>
    <GridLength x:Key="GridHeaderTracksGenreColumnWidth">250</GridLength>
    <GridLength x:Key="GridHeaderTracksScoreColumnWidth">150</GridLength>
    <GridLength x:Key="GridHeaderTracksHeight">25</GridLength>

    <!-- Grid item dimensions -->
    <x:Double x:Key="GridItemHeight">310</x:Double>
    <x:Double x:Key="GridItemWidth">310</x:Double>
    <GridLength x:Key="FavoriteButtonColumnWidth">50</GridLength>
</ResourceDictionary>