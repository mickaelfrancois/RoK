<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary    
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:common="using:Rok.Commons">

    <DataTemplate x:Key="AlbumsGrid">
        <Grid HorizontalAlignment="Left" Width="300" Height="300" Margin="4" BorderBrush="Gray" BorderThickness="0">
            <Border>
                <common:PictureControl Padding="0" Margin="0" Cover="{Binding Picture, Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Center" Icon="&#xE8D4;" PlayButtonVisibility="Visible" Command="{Binding ListenCommand}"/>
            </Border>

            <Grid VerticalAlignment="Bottom" Background="#CC000000" Height="60" Margin="2,0,2,2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                </Grid.RowDefinitions>

                <HyperlinkButton Margin="4,0,0,0" FontSize="18" Width="300" Content="{Binding Name}"  Style="{StaticResource HyperlinkSmallButtonStyle}" Foreground="LightGreen"  HorizontalAlignment="Left" HorizontalContentAlignment="Left" Command="{Binding AlbumOpenCommand}"/>
                <SymbolIcon HorizontalAlignment="Right" Symbol="Favorite" Foreground="Yellow" Visibility="{Binding IsFavorite}"></SymbolIcon>

                <HyperlinkButton Grid.Row="1" Margin="4,0,0,0" FontSize="18" Width="300" Content="{Binding ArtistName}" Command="{Binding ArtistOpenCommand}"  Style="{StaticResource HyperlinkSmallButtonStyle}" Foreground="White" HorizontalAlignment="Left" HorizontalContentAlignment="Left" />
                <SymbolIcon Grid.Row="1" HorizontalAlignment="Right" Symbol="Favorite" Foreground="Yellow" Visibility="{Binding IsArtistFavorite}"></SymbolIcon>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="AlbumsGroupCategory">
        <StackPanel Orientation="Horizontal" Visibility="Visible">
            <HyperlinkButton Content="{Binding Title}" Style="{StaticResource HyperlinkGroupButtonStyle}"></HyperlinkButton>
            <Button Style="{StaticResource ButtonTextBlockStyle}" Margin="10,0,0,0" Command="{Binding ElementName=albumsView, Path=DataContext.AlbumsListenGroupCommand}" CommandParameter="{Binding}" VerticalAlignment="Bottom" Tapped="GroupButton_Tapped" >
                <StackPanel Orientation="Horizontal" >
                    <TextBlock Text="&#xE14B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"></TextBlock>
                    <TextBlock x:Uid="albumsViewListenListGroup" FontFamily="Segoe UI" VerticalAlignment="Center"></TextBlock>
                </StackPanel>
            </Button>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
