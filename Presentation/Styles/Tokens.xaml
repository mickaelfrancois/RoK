<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary palette -->
    <SolidColorBrush x:Key="PrimaryThemeBrush"
                     Color="#154587" />
    <SolidColorBrush x:Key="PrimaryHoverThemeBrush"
                     Color="#0D2A54" />
    <SolidColorBrush x:Key="PrimaryPressedThemeBrush"
                     Color="#123D7A" />

    <!-- Accent palette -->
    <SolidColorBrush x:Key="DefaultThemeBrush"
                     Color="#257EF9" />
    <SolidColorBrush x:Key="HoverThemeBrush"
                     Color="#257EF9" />
    <SolidColorBrush x:Key="PressedThemeBrush"
                     Color="#123D7A" />

    <!-- Badge colors -->
    <SolidColorBrush x:Key="BadgeLiveBrush"
                     Color="DarkCyan" />
    <SolidColorBrush x:Key="BadgeCompilationBrush"
                     Color="DarkViolet" />
    <SolidColorBrush x:Key="BadgeNewBrush"
                     Color="DarkOrange" />
    <SolidColorBrush x:Key="BadgeBestOfBrush"
                     Color="DarkBlue" />
    
    <!-- Layout -->
    <x:Double x:Key="SmallHeaderHeight">100</x:Double>

    <!-- Opacity -->
    <x:Double x:Key="HeaderBackgroundOpacity">0.9</x:Double>
    <x:Double x:Key="HeaderBackdropOpacity">0.1</x:Double>

    <!-- Paths -->
    <x:String x:Key="HeartPath">M12,21 C12,21 4,13.36 4,8.5 C4,5.42 6.42,3 9.5,3 C11.24,3 12,4.1 12,4.1 C12,4.1 12.76,3 14.5,3 C17.58,3 20,5.42 20,8.5 C20,13.36 12,21 12,21 Z</x:String>

</ResourceDictionary>