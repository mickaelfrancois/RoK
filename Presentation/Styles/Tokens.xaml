<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary palette -->
    <SolidColorBrush x:Key="PrimaryThemeBrush"
                     Color="#154587" />
    <SolidColorBrush x:Key="PrimaryHoverThemeBrush"
                     Color="#0D2A54" />
    <SolidColorBrush x:Key="PrimaryPressedThemeBrush"
                     Color="#123D7A" />
    <SolidColorBrush x:Key="LikeCheckedBackgroundBrush"
                     Color="#206cd3" />

    <!-- Accent palette -->
    <SolidColorBrush x:Key="DefaultThemeBrush"
                     Color="#257EF9" />
    <SolidColorBrush x:Key="HoverThemeBrush"
                     Color="#257EF9" />
    <SolidColorBrush x:Key="PressedThemeBrush"
                     Color="#123D7A" />

    <!-- Badge colors -->
    <SolidColorBrush x:Key="BadgeLiveBrush"
                     Color="DarkCyan" />
    <SolidColorBrush x:Key="BadgeCompilationBrush"
                     Color="DarkViolet" />
    <SolidColorBrush x:Key="BadgeNewBrush"
                     Color="DarkOrange" />
    <SolidColorBrush x:Key="BadgeBestOfBrush"
                     Color="DarkBlue" />

    <!-- Navigation -->
    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground1"
                     Color="#F1F1F1" />
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground1"
                     Color="#313131" />
    <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>

    <SolidColorBrush x:Key="LikeCheckedBackgroundBrush"
                     Color="#206cd3" />

    <!-- Layout -->
    <x:Double x:Key="LargeHeaderHeight">280</x:Double>
    <x:Double x:Key="NormalHeaderHeight">180</x:Double>
    <x:Double x:Key="SmallHeaderHeight">100</x:Double>
    <x:Double x:Key="LargeScreenBreakpoint">1230</x:Double>
    <x:Double x:Key="MediumScreenBreakpoint">640</x:Double>

    <!-- Opacity -->
    <x:Double x:Key="HeaderBackgroundOpacity">0.9</x:Double>
    <x:Double x:Key="HeaderBackdropOpacity">0.1</x:Double>

    <!-- Thickness -->
    <Thickness x:Key="ScrollAwareThickness">0,0,17,0</Thickness>
    <Thickness x:Key="ScrollHeaderThickness">0,0,130,0</Thickness>
    <Thickness x:Key="LargeHeaderThickness">0,280,0,0</Thickness>
    <Thickness x:Key="NormalHeaderThickness">0,130,0,0</Thickness>

    <!-- Paths -->
    <x:String x:Key="HeartPath">M12,21 C12,21 4,13.36 4,8.5 C4,5.42 6.42,3 9.5,3 C11.24,3 12,4.1 12,4.1 C12,4.1 12.76,3 14.5,3 C17.58,3 20,5.42 20,8.5 C20,13.36 12,21 12,21 Z</x:String>

</ResourceDictionary>