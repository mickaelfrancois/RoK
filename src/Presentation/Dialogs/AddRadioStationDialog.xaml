<ContentDialog x:Class="Rok.Dialogs.AddRadioStationDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Uid="addRadioDialog"
               DefaultButton="Primary"
               PrimaryButtonClick="OnSaveClick">
    <StackPanel Spacing="12" MinWidth="380">
        <TextBox x:Name="NameBox" x:Uid="addRadioName" />
        <TextBox x:Name="UrlBox" x:Uid="addRadioUrl" />
        <TextBox x:Name="HomepageBox" x:Uid="addRadioHomepage" />
        <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
