<ContentDialog x:Class="Rok.Dialogs.PlayRadioUrlDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               x:Uid="playRadioUrlDialog"
               DefaultButton="Primary"
               PrimaryButtonClick="OnPlayClick">
    <StackPanel Spacing="12" MinWidth="380">
        <TextBox x:Name="UrlBox" x:Uid="playRadioUrl" />
        <TextBlock x:Uid="playRadioUrlHint" Foreground="Gray" TextWrapping="Wrap" />
        <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
