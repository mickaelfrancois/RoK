<?xml version="1.0" encoding="utf-8"?>
<Application x:Class="Rok.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Rok"
             xmlns:converters="using:Rok.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <BitmapImage x:Key='artistPictureFallback' UriSource='Assets/artistFallback.png' />

            <x:String x:Key="ArtistFallbackPictureUri">ms-appx:///Assets/artistFallback.png</x:String>

            <x:Int32 x:Key="SleepTimer5">5</x:Int32>
            <x:Int32 x:Key="SleepTimer10">10</x:Int32>
            <x:Int32 x:Key="SleepTimer15">15</x:Int32>
            <x:Int32 x:Key="SleepTimer30">30</x:Int32>
            <x:Int32 x:Key="SleepTimer45">45</x:Int32>
            <x:Int32 x:Key="SleepTimer60">60</x:Int32>

            <converters:BoolToGridLengthAutoConverter x:Key="BoolToGridLengthAutoConverter" />
            <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
            <converters:ColorToAccentBrushConverter x:Key="ColorToAccentBrushConverter" />
            <converters:ColorToGradientBrushConverter x:Key="ColorToGradientBrushConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolToInvertBoolConverter x:Key="BoolToInvertBoolConverter" />
            <converters:CountryCodeToImageSourceConverter x:Key="CountryCodeToImageSourceConverter" />
            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
            <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
            <converters:LongToTimespanConverter x:Key="LongToTimespanConverter" />
            <converters:DoubleToTimespanConverter x:Key="DoubleToTimespanConverter" />
            <converters:TimeSpanToDoubleConverter x:Key="TimeSpanToDoubleConverter" />
            <converters:BoolToInvertVisibilityConverter x:Key="BoolToInvertVisibilityConverter" />
            <converters:PlaybackStateToButtonIconConverter x:Key="PlaybackStateToButtonIconConverter" />
            <converters:VolumeToGlyphConverter x:Key="VolumeToGlyphConverter" />
            <converters:GridListIconConverter x:Key="GridListIconConverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
            <converters:NumberToFormattedStringConverter x:Key="NumberToFormattedStringConverter" />
            <converters:IntToColorConverter x:Key="IntToColorConverter" />
            <converters:SecondsToReadableConverter x:Key="SecondsToReadableConverter" />
            <converters:LanguageAutoTranslationConverter x:Key="LanguageAutoTranslationConverter" />
            <converters:LyricColorConverter x:Key="LyricColorConverter" />
            <converters:LyricsTypeVisibilityConverter x:Key="LyricsTypeVisibilityConverter" />
            
            <converters:BoolToColorConverter x:Key="FavoriteToColorConverter">
                <converters:BoolToColorConverter.TrueBrush>
                    <SolidColorBrush Color="Gold" />
                </converters:BoolToColorConverter.TrueBrush>
                <converters:BoolToColorConverter.FalseBrush>
                    <SolidColorBrush Color="Gray" />
                </converters:BoolToColorConverter.FalseBrush>
            </converters:BoolToColorConverter>

            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Styles/Tokens.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/ControlsStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/RatingControlStyles.xaml" />

                <!-- Tokens -->
                <ResourceDictionary Source="ms-appx:///Styles/Tokens/Colors.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/Tokens/Icons.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/Tokens/Semantics.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/Tokens/Typography.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/Tokens/Spacing.xaml" />
                <!-- Components -->
                <ResourceDictionary Source="ms-appx:///Styles/Components/ControlsStyles.xaml" />
                <!-- Templates -->

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
