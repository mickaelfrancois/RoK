<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Rok.Commons.ListeningStatsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vmcommon="using:Rok.ViewModels.Common"
             mc:Ignorable="d">

    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Height="3" CornerRadius="7,7,0,0" Background="{x:Bind AccentBrush, Mode=OneWay}" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,16">
                <StackPanel Spacing="16">
                    <TextBlock x:Uid="albumStatsHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                    <TextBlock x:Uid="albumStatsNeverListened" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" Visibility="{x:Bind Stats.ShowNeverListened, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <StackPanel Spacing="16" Visibility="{x:Bind Stats.ShowStats, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{x:Bind Stats.ListenCountValue, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Uid="albumStatsListensLabel" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="{x:Bind Stats.DurationValue, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Uid="albumStatsDurationLabel" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="{x:Bind Stats.SinceValue, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Uid="albumStatsSinceLabel" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="{x:Bind Stats.PeakHourValue, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Uid="albumStatsPeakLabel" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <ItemsControl Height="40" ItemsSource="{x:Bind Stats.MonthlyBars, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vmcommon:MonthlyBarViewModel">
                                        <Rectangle Width="12" Height="{x:Bind Height}" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentFillColorDefaultBrush}" ToolTipService.ToolTip="{x:Bind Tooltip}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Uid="albumStatsTrendLabel" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="4" Visibility="{x:Bind Stats.ShowProgression, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar Maximum="{x:Bind Stats.TotalItemCount, Mode=OneWay}" Value="{x:Bind Stats.ListenedItemCount, Mode=OneWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind Stats.ProgressionLabel, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ProgressionUnitText, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
