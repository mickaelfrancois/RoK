<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Rok.Commons.CompactPlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Rok.Commons"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="0"
          Padding="0"
          Background="Transparent"
          DoubleTapped="Grid_DoubleTapped">

        <!-- Music background: artist / album cover -->
        <Image Source="{x:Bind PlayerViewModel.CurrentArtist.Picture, Mode=OneWay, TargetNullValue={Binding PlayerViewModel.MediaList.CurrentItem.Cover}}"
               Stretch="UniformToFill"
               Opacity="0.55"
               Visibility="{x:Bind PlayerViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Radio background: brand-coloured panel with a centred radio glyph -->
        <Grid Background="{ThemeResource BrandPrimaryBrush}"
              Visibility="{x:Bind PlayerViewModel.IsRadioMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <FontIcon Glyph="&#xE8D6;" FontFamily="Segoe Fluent Icons"
                      FontSize="96" Foreground="White" Opacity="0.25"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <Grid VerticalAlignment="Bottom"
              Height="130">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="0,1">
                    <GradientStop Color="#00000000"
                                  Offset="0.0" />
                    <GradientStop Color="#DD000000"
                                  Offset="0.6" />
                    <GradientStop Color="#FF000000"
                                  Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Music info: track title + artist -->
                <StackPanel Grid.Row="0"
                            Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="10,6,10,4"
                            Visibility="{x:Bind PlayerViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <!-- Title shadow + text -->
                    <Grid>
                        <TextBlock Text="{x:Bind PlayerViewModel.CurrentTrack.Title, Mode=OneWay}"
                                   Foreground="#AA000000"
                                   FontWeight="Bold"
                                   FontSize="24"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"
                                   HorizontalAlignment="Center"
                                   Margin="8,2,8,0" />
                        <TextBlock x:Name="title"
                                   Text="{x:Bind PlayerViewModel.CurrentTrack.Title, Mode=OneWay}"
                                   Foreground="#FFFFFFFF"
                                   FontWeight="Bold"
                                   FontSize="24"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"
                                   HorizontalAlignment="Center"
                                   Margin="6,0,6,0" />
                    </Grid>

                    <!-- Artist shadow + text -->
                    <Grid Margin="0,2,0,0">
                        <TextBlock Text="{x:Bind PlayerViewModel.CurrentTrack.ArtistName, Mode=OneWay}"
                                   Foreground="#AA000000"
                                   FontSize="20"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"
                                   HorizontalAlignment="Center"
                                   Margin="8,2,8,0" />
                        <TextBlock x:Name="artist"
                                   Text="{x:Bind PlayerViewModel.CurrentTrack.ArtistName, Mode=OneWay}"
                                   Foreground="#FFFFFFFF"
                                   FontSize="20"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"
                                   HorizontalAlignment="Center"
                                   Margin="6,0,6,0" />
                    </Grid>
                </StackPanel>

                <!-- Radio info: LIVE badge + station name + stream title -->
                <StackPanel Grid.Row="0"
                            Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="10,6,10,4"
                            Spacing="4"
                            Visibility="{x:Bind PlayerViewModel.IsRadioMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Border Background="{ThemeResource BadgeLiveBrush}"
                            CornerRadius="4"
                            HorizontalAlignment="Center"
                            Padding="8,2">
                        <TextBlock Text="LIVE" Foreground="White" FontSize="11" FontWeight="Bold" />
                    </Border>

                    <TextBlock Text="{x:Bind PlayerViewModel.CurrentStationName, Mode=OneWay}"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="22"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="260"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="{x:Bind PlayerViewModel.CurrentStreamTitle, Mode=OneWay}"
                               Foreground="White"
                               Opacity="0.85"
                               FontSize="14"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="260"
                               HorizontalAlignment="Center"
                               Visibility="{x:Bind PlayerViewModel.CurrentStreamTitle, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>

                <!-- Progress (music): elapsed / total -->
                <ProgressBar Grid.Row="1"
                             Margin="12,4,12,8"
                             Minimum="0"
                             Maximum="{x:Bind PlayerViewModel.DurationTotal.TotalSeconds, Mode=OneWay}"
                             Value="{x:Bind PlayerViewModel.ListenDuration.TotalSeconds, Mode=OneWay}"
                             IsIndeterminate="False"
                             Height="2"
                             Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                             Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                             Visibility="{x:Bind PlayerViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Buffering pulse (radio): visible only while the stream is rebuffering -->
                <ProgressBar Grid.Row="1"
                             Margin="12,4,12,8"
                             IsIndeterminate="True"
                             Height="2"
                             Foreground="{ThemeResource BadgeLiveBrush}"
                             Background="Transparent"
                             Visibility="{x:Bind PlayerViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Controls -->
                <CommandBar Grid.Row="2"
                            Background="Transparent"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,2"
                            DefaultLabelPosition="Collapsed"
                            IsDynamicOverflowEnabled="False"
                            OverflowButtonVisibility="Collapsed">

                    <AppBarButton RequestedTheme="Dark"
                                  Style="{StaticResource AppBarButtonRevealStyle}"
                                  Icon="Previous"
                                  Command="{x:Bind PlayerViewModel.SkipPreviousCommand}"
                                  IsEnabled="{x:Bind PlayerViewModel.CanSkipPrevious, Mode=OneWay}"
                                  Visibility="{x:Bind PlayerViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <AppBarButton RequestedTheme="Dark"
                                  Style="{StaticResource AppBarButtonRevealStyle}"
                                  Command="{x:Bind PlayerViewModel.TogglePlayPauseCommand}">
                        <SymbolIcon Symbol="{x:Bind PlayerViewModel.PlaybackState, Mode=OneWay, Converter={StaticResource PlaybackStateToButtonIconConverter}}" />
                    </AppBarButton>

                    <AppBarButton RequestedTheme="Dark"
                                  Style="{StaticResource AppBarButtonRevealStyle}"
                                  Icon="Next"
                                  Command="{x:Bind PlayerViewModel.SkipNextCommand}"
                                  IsEnabled="{x:Bind PlayerViewModel.CanSkipNext, Mode=OneWay}"
                                  Visibility="{x:Bind PlayerViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </CommandBar>
            </Grid>
        </Grid>

        <!-- Compact mode toggle -->
        <Button x:Name="btCompactMode"
                Background="Transparent"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                RequestedTheme="Dark"
                Command="{x:Bind PlayerViewModel.CompactModeCommand}"
                Margin="0,6,6,0"
                Padding="6"
                ToolTipService.ToolTip="Exit compact mode">
            <SymbolIcon Symbol="StopSlideShow" />
        </Button>
    </Grid>
</UserControl>