<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Rok.Commons.LyricText"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <!-- Outline layer: 4 TextBlocks offset ±2px to simulate a stroke -->
        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                   Foreground="Black"
                   Opacity="0.85"
                   FontSize="52"
                   FontFamily="Segoe UI Variable"
                   FontWeight="Black"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="1200">
            <TextBlock.RenderTransform>
                <TranslateTransform X="-2" Y="-2" />
            </TextBlock.RenderTransform>
        </TextBlock>

        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                   Foreground="Black"
                   Opacity="0.85"
                   FontSize="52"
                   FontFamily="Segoe UI Variable"
                   FontWeight="Black"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="1200">
            <TextBlock.RenderTransform>
                <TranslateTransform X="2" Y="-2" />
            </TextBlock.RenderTransform>
        </TextBlock>

        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                   Foreground="Black"
                   Opacity="0.85"
                   FontSize="52"
                   FontFamily="Segoe UI Variable"
                   FontWeight="Black"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="1200">
            <TextBlock.RenderTransform>
                <TranslateTransform X="-2" Y="2" />
            </TextBlock.RenderTransform>
        </TextBlock>

        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                   Foreground="Black"
                   Opacity="0.85"
                   FontSize="52"
                   FontFamily="Segoe UI Variable"
                   FontWeight="Black"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="1200">
            <TextBlock.RenderTransform>
                <TranslateTransform X="2" Y="2" />
            </TextBlock.RenderTransform>
        </TextBlock>
      
        <!-- Main text layer -->
        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                   Foreground="{x:Bind LyricColor, Mode=OneWay}"
                   FontSize="52"
                   FontFamily="Segoe UI Variable"
                   FontWeight="Black"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="1200" />
    </Grid>
</UserControl>
