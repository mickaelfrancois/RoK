<Page x:Class="Rok.Pages.RadiosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Rok.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:common="using:Rok.Commons"
      xmlns:vm="using:Rok.ViewModels.Radio"
      mc:Ignorable="d"
      x:Name="radiosView">

    <Page.Resources>
        <DataTemplate x:Key="RadioGridTemplate" x:DataType="vm:RadioTileViewModel">
            <Grid Style="{StaticResource MainGridCoverStyle}">
                <Grid.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="radiosFlyoutPlay"
                                        Click="OnTileNameClick"
                                        Tag="{x:Bind}">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Play" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="radiosFlyoutEdit"
                                        Click="OnEditMenuClick"
                                        Tag="{x:Bind}">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Edit" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="radiosFlyoutPickImage"
                                        Click="OnPickImageMenuClick"
                                        Tag="{x:Bind}">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Pictures" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="radiosFlyoutDelete"
                                        Click="OnDeleteMenuClick"
                                        Tag="{x:Bind}">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Delete" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Grid.ContextFlyout>

                <!-- Cover: cached station picture (if available) over a brand-coloured fallback panel with a centred radio glyph -->
                <Border CornerRadius="{StaticResource CornerRadiusMediumValue}" Background="{ThemeResource BrandPrimaryBrush}">
                    <Grid>
                        <FontIcon Glyph="&#xE8D6;"
                                  FontSize="56" Foreground="White" Opacity="0.35"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Image Source="{x:Bind Picture, Mode=OneWay}"
                               Stretch="UniformToFill" />
                    </Grid>
                </Border>

                <!-- LIVE badge -->
                <Border Background="{ThemeResource BadgeLiveBrush}"
                        CornerRadius="4"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0" Padding="6,2">
                    <TextBlock Text="LIVE" Foreground="White" FontSize="10" FontWeight="Bold" />
                </Border>

                <!-- Country flag badge (only when CountryCode is known) -->
                <Border CornerRadius="2"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="8,8,0,0"
                        Visibility="{x:Bind CountryCode, Converter={StaticResource StringToVisibilityConverter}}">
                    <Image Width="22" Height="15"
                           Source="{x:Bind CountryCode, Converter={StaticResource CountryCodeToImageSourceConverter}}" />
                </Border>

                <Grid x:Name="gridBottom" Style="{StaticResource GridCoverBottomStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{StaticResource GridBottomFirstRowHeight}" />
                        <RowDefinition Height="{StaticResource GridBottomSecondRowHeight}" />
                    </Grid.RowDefinitions>

                    <HyperlinkButton Content="{x:Bind Name}"
                                     Click="OnTileNameClick"
                                     Tag="{x:Bind}"
                                     Style="{StaticResource GridCoverButtonStyle}" />

                    <TextBlock Grid.Row="1"
                               Text="{x:Bind common:RadioDisplay.FormatTechnical(Codec, Bitrate)}"
                               Style="{StaticResource GridCoverBottomSecondLineStyle}"
                               Margin="4,6,0,0" />
                </Grid>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" Style="{StaticResource HeaderCommandBarListStyle}">
            <CommandBar.Content>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="{StaticResource SpacingSmall}">
                    <AppBarButton x:Uid="radiosSearch"
                                  Style="{StaticResource AppBarButtonCompactStyle}"
                                  Click="OnSearchClick">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Find"/>
                        </AppBarButton.Icon>
                    </AppBarButton>

                    <AppBarButton x:Uid="radiosPlayUrl"
                                  Style="{StaticResource AppBarButtonCompactStyle}"
                                  Click="OnPlayUrlClick">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE774;" />
                        </AppBarButton.Icon>
                    </AppBarButton>

                    <AppBarButton x:Uid="radiosAdd"
                                  Icon="Add"
                                  Style="{StaticResource AppBarButtonCompactStyle}"
                                  Click="OnAddClick" />
                </StackPanel>
            </CommandBar.Content>
        </CommandBar>

        <Grid Grid.Row="1" Style="{StaticResource GridListStyle}">
            <common:GridViewExtended x:Name="grid"
                                     ItemsSource="{x:Bind ViewModel.Stations}"
                                     ItemTemplate="{StaticResource RadioGridTemplate}"
                                     ItemsPanel="{StaticResource GridPanelTemplate}"
                                     SelectionMode="None"
                                     IsItemClickEnabled="False"
                                     ScrollViewer.VerticalScrollMode="Enabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />

            <common:EmptyStateControl x:Uid="radiosNoData"
                                      Glyph="&#xE8D6;"
                                      Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</Page>
