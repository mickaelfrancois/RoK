<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Rok.Pages.OptionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Rok.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:statistics="using:Rok.ViewModels.Statistics"
      xmlns:controls="using:Rok.Commons"
      mc:Ignorable="d"
      x:Name="OptionsView">

    <Grid>
        <Pivot>
            <PivotItem x:Uid="OptionTabOptions">
                <Border Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="4" CornerRadius="12" Margin="8">
                    <StackPanel Spacing="10" Margin="6,12,0,0">
                        <StackPanel Orientation="Vertical" Spacing="12" VerticalAlignment="Center">
                            <TextBlock x:Uid="optionsThemeLabel" VerticalAlignment="Center" />
                            <ComboBox Width="220" SelectedValuePath="Tag" SelectedValue="{x:Bind ThemeString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem x:Uid="optionsThemeSystemItem" Tag="System" />
                                <ComboBoxItem x:Uid="optionsThemeLightItem" Tag="Light" />
                                <ComboBoxItem x:Uid="optionsThemeDarkItem" Tag="Dark" />
                            </ComboBox>

                            <!-- Language Selection -->
                            <TextBlock x:Uid="optionsLanguageLabel" VerticalAlignment="Center" />
                            <ComboBox Width="220" ItemsSource="{x:Bind AvailableLanguages}" SelectedValue="{x:Bind SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding}" />
                                            <TextBlock x:Uid="optionsLanguageAutoTranslation" Visibility="{Binding Converter={StaticResource LanguageAutoTranslationConverter}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <ToggleSwitch x:Uid="OptionsHideArtistsSwitch"
                                      IsOn="{x:Bind Options.HideArtistsWithoutAlbum, Mode=TwoWay}"
                                      x:Name="HideArtistsSwitch"
                                      VerticalAlignment="Center" />
                        <ToggleSwitch x:Uid="OptionsCrossFadeSwitch"
                                      x:Name="OptionsCrossFadeSwitch"
                                      IsOn="{x:Bind Options.CrossFade, Mode=TwoWay}" />
                        <ToggleSwitch x:Uid="optionsRefreshAtStartupSwitch"
                                      x:Name="optionsRefreshAtStartupSwitch"
                                      IsOn="{x:Bind Options.RefreshLibraryAtStartup, Mode=TwoWay}" />
                        <ToggleSwitch x:Uid="OptionsImportWithArtistGenreSwitch"
                                      IsOn="{x:Bind Options.ImportTrackWithArtistGenre, Mode=TwoWay}" />
                        <ToggleSwitch x:Uid="OptionsPauseOnCall"
                                      IsOn="{x:Bind Options.PauseOnCall, Mode=TwoWay}" />
                        <ToggleSwitch x:Uid="OptionsNovaApiEnabledSwitch"
                                      IsOn="{x:Bind Options.NovaApiEnabled, Mode=TwoWay}" />
                        <ToggleSwitch x:Uid="OptionsTelemetryEnabledSwitch"
                                      IsOn="{x:Bind Options.TelemetryEnabled, Mode=TwoWay}" />

                    </StackPanel>
                </Border>
            </PivotItem>

            <PivotItem x:Uid="OptionTabShortcuts">
                <Border Background="{ThemeResource CardBackgroundFillColorDefault}"
                        Padding="4"
                        CornerRadius="12"
                        Margin="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="6,12,12,12">
                        <controls:KeyboardShortcutsView />
                    </ScrollViewer>
                </Border>
            </PivotItem>

            <PivotItem x:Uid="OptionTabLibrary">
                <Border Background="{ThemeResource CardBackgroundFillColorDefault}"
                        Padding="4"
                        CornerRadius="12"
                        Margin="8">
                    <StackPanel Spacing="10"
                                Margin="6,12,0,0">

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button x:Uid="AddLibraryFolderButton"
                                    x:Name="AddLibraryFolderButton"
                                    Click="AddLibraryFolderButton_Click" />
                            <Button x:Uid="RemoveLibraryFolderButton"
                                    x:Name="RemoveLibraryFolderButton"
                                    Click="RemoveLibraryFolderButton_Click" />
                        </StackPanel>

                        <ListView x:Name="LibraryPathsList"
                                  ItemsSource="{x:Bind Paths}"
                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                  BorderThickness="1"
                                  SelectionMode="Single"
                                  Height="120"
                                  Width="420"
                                  HorizontalAlignment="Left">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:PathItem">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <FontIcon Glyph="&#xE8B7;"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind Value}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </PivotItem>

            <PivotItem x:Uid="OptionTabCommand">
                <Border Background="{ThemeResource CardBackgroundFillColorDefault}" Padding="4" CornerRadius="12" Margin="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16" Margin="6,12,12,12">

                            <TextBlock x:Uid="CommandTabApiConfigTitle" Text="API Configuration" FontWeight="SemiBold" FontSize="14" />

                            <StackPanel Spacing="10">
                                <ToggleSwitch x:Uid="OptionsHideEnableWebApi" Header="Enable Web API" x:Name="HideEnableWebApi" IsOn="{x:Bind Options.EnableWebApi, Mode=TwoWay}" VerticalAlignment="Center" />
                                <NumberBox x:Uid="OptionsWebApiPort" Header="Web API Port" x:Name="WebApiPort" Value="{x:Bind Options.WebApiPort, Mode=TwoWay}" Minimum="1" Maximum="65535" VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" MaxWidth="100" />
                            </StackPanel>

                            <Line Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="1" X1="0" Y1="0" X2="800" Y2="0" />

                            <!-- Web API documentation -->
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="CommandTabApiDocTitle" Text="Web API" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock x:Uid="CommandTabApiDocBaseUrl" Text="Base URL: http://localhost:{port}/api" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                <Border Background="{ThemeResource ContentDialogBackground}" CornerRadius="8" Padding="12,8">
                                    <StackPanel Spacing="0">

                                        <!-- Header row -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" x:Uid="CommandTabHeaderMethod" Text="Method" FontWeight="SemiBold" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="1" x:Uid="CommandTabHeaderEndpoint" Text="Endpoint" FontWeight="SemiBold" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="2" x:Uid="CommandTabHeaderDescription" Text="Description" FontWeight="SemiBold" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="3" x:Uid="CommandTabHeaderTest" Text="Test" FontWeight="SemiBold" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                        </Grid>

                                        <Line Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" StrokeThickness="1" X1="0" Y1="0" X2="700" Y2="0" Margin="0,0,0,6" />

                                        <!-- /api/status -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/status" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointStatusDesc" Text="Returns the current playback status (state, volume, position)" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/status" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/current -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/current" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointCurrentDesc" Text="Returns information about the current track (title, artist, album, duration)" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/current" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/queue -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/queue" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointQueueDesc" Text="Returns the current playback queue" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/queue" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/play -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/play" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointPlayDesc" Text="Start or resume playback" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/play" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/pause -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/pause" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointPauseDesc" Text="Pause playback" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/pause" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/toggle -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/toggle" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointToggleDesc" Text="Stop playback" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/toggle" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/next -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/next" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointNextDesc" Text="Skip to the next track" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/next" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/previous -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/previous" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointPreviousDesc" Text="Go to the previous track" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/previous" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/listen/playlist/{name} -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/listen/playlist/{name}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointPlayPlaylistDesc" Text="Start listen a playlist" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/listen/playlist/radio" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/listen/album/{name} -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/listen/album/{name}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointPlayAlbumDesc" Text="Start listen an album" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/listen/album/thriller" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/listen/artist/{name} -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/listen/artist/{name}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointPlayArtistDesc" Text="Start listen an artist" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/listen/artist/madonna" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/listen/genre/{name} -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/listen/genre/{name}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointPlayGenreDesc" Text="Start listen a genre" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/listen/genre/rock" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/volume/{value} — inline NumberBox for the test value -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/volume/{value}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointVolumeDesc" Text="Set the volume. Value must be between 0 and 100" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/volume/20" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- /api/mute -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="GET" FontFamily="Consolas" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="/mute/" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" x:Uid="ApiEndpointMuteDesc" Text="Mute the volume" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="3" Tag="/mute/" Click="TestEndpoint_Click" Content="▶ Test" FontSize="11" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Line Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="1" X1="0" Y1="0" X2="800" Y2="0" />

                            <!-- Command Line documentation -->
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="CommandTabCliTitle" Text="Command Line" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock x:Uid="CommandTabCliUsage" Text="Usage: rok.exe [command] [argument]" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                <Border Background="{ThemeResource ContentDialogBackground}" CornerRadius="8" Padding="12,8">
                                    <StackPanel Spacing="0">
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" x:Uid="CommandTabHeaderCommand" Text="Command" FontWeight="SemiBold" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="1" x:Uid="CommandTabHeaderCommandDescription" Text="Description" FontWeight="SemiBold" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Grid>

                                        <Line Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" StrokeThickness="1" X1="0" Y1="0" X2="700" Y2="0" Margin="0,0,0,6" />

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok play" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliPlayDesc" Text="Start or resume playback" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok pause" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliPauseDesc" Text="Pause playback" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok next" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliNextDesc" Text="Skip to the next track" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok prev" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliPrevDesc" Text="Go to the previous track" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok volume {volume 0-100}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliVolumeDesc" Text="Set the volume level" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok mute" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliMuteDesc" Text="Mute the volume" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok listen playlist {playlist}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliListenPlaylistDesc" Text="Start listen a playlist" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok listen album {album}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliListenAlbumDesc" Text="Start listen an album" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok listen artist {artist}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliListenArtistDesc" Text="Start listen an artist" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="240" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="rok listen genre {genre}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Uid="CliListenGenreDesc" Text="Start listen a genre" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </PivotItem>

            <PivotItem x:Uid="OptionTabStatistics">

                <Border Background="{ThemeResource CardBackgroundFillColorDefault}"
                        Padding="4"
                        CornerRadius="12"
                        Margin="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <CommandBar Style="{StaticResource HeaderCommandBarStyle}"
                                    HorizontalAlignment="Left">
                            <AppBarButton x:Uid="resetListenCount"
                                          Style="{StaticResource HeaderGenericButtonStyle}"
                                          Icon="Refresh"
                                          Click="ResetListenCount_Click">
                                <ToolTipService.ToolTip>
                                    <TextBlock x:Uid="resetListenCountToolTip" />
                                </ToolTipService.ToolTip>
                            </AppBarButton>
                        </CommandBar>

                        <ScrollViewer Height="auto"
                                      Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">

                            <StackPanel Spacing="16"
                                        Margin="24,18,24,18">


                                <ItemsControl>
                                    <ItemsControl.Items>
                                        <TextBlock>
                                    <Run x:Uid="StatGenres"
                                            FontWeight="Bold" />
                                    <Run Text="{x:Bind StatisticsViewModel.FormatWithThousands(StatisticsViewModel.Current.TotalGenres), Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock>
                                    <Run x:Uid="StatArtists"
                                            FontWeight="Bold" />
                                    <Run Text="{x:Bind StatisticsViewModel.FormatWithThousands(StatisticsViewModel.Current.TotalArtists), Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock>
                                    <Run x:Uid="StatAlbums"
                                            FontWeight="Bold" />
                                    <Run Text="{x:Bind StatisticsViewModel.FormatWithThousands(StatisticsViewModel.Current.TotalAlbums), Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock>
                                    <Run x:Uid="StatSongs"
                                            FontWeight="Bold" />
                                    <Run Text="{x:Bind StatisticsViewModel.FormatWithThousands(StatisticsViewModel.Current.TotalTracks), Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock>
                                    <Run x:Uid="StatListened"
                                            FontWeight="Bold" />
                                    <Run Text="{x:Bind StatisticsViewModel.FormatWithThousands(StatisticsViewModel.Current.TracksListenedCount), Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock>
                                    <Run x:Uid="StatTotalDurations"
                                            FontWeight="Bold" />
                                    <Run Text="{x:Bind StatisticsViewModel.TotalDuration, Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock>
                                    <Run x:Uid="StatTotalSize"
                                            FontWeight="Bold" />
                                    <Run Text="{x:Bind StatisticsViewModel.TotalSize, Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock>
                                    <Run x:Uid="StatTotalRawLyrics"
                                            FontWeight="Bold" />
                                            <Run Text="{x:Bind StatisticsViewModel.FormatWithThousands(StatisticsViewModel.TotalRawLyrics), Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock>
                                    <Run x:Uid="StatTotalSyncLyrics"
                                            FontWeight="Bold" />
                                        <Run Text="{x:Bind StatisticsViewModel.FormatWithThousands(StatisticsViewModel.TotalSyncLyrics), Mode=OneWay}" />
                                        </TextBlock>

                                    </ItemsControl.Items>
                                </ItemsControl>

                                <!-- Top lists: three columns side by side -->
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12">

                                    <!-- Top Genres -->
                                    <Border Background="{ThemeResource ContentDialogBackground}"
                                            Padding="8"
                                            CornerRadius="8"
                                            Width="300">
                                        <StackPanel>
                                            <TextBlock x:Uid="StatTopGenres"
                                                       FontWeight="SemiBold"
                                                       FontSize="14" />
                                            <ScrollViewer Height="550"
                                                          VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{x:Bind StatisticsViewModel.TopGenres, Mode=OneWay}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="statistics:RankedTopItem">
                                                            <Grid Margin="4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="32" />
                                                                    <ColumnDefinition Width="160" />
                                                                    <ColumnDefinition Width="60" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{x:Bind Rank}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{x:Bind Name}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{x:Bind ListenCount}"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <!-- Top Artists -->
                                    <Border Background="{ThemeResource ContentDialogBackground}"
                                            Padding="8"
                                            CornerRadius="8"
                                            Width="300">
                                        <StackPanel>
                                            <TextBlock x:Uid="StatTopArtists"
                                                       FontWeight="SemiBold"
                                                       FontSize="14" />
                                            <ScrollViewer Height="550"
                                                          VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{x:Bind StatisticsViewModel.TopArtists, Mode=OneWay}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="statistics:RankedTopItem">
                                                            <Grid Margin="4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="32" />
                                                                    <ColumnDefinition Width="160" />
                                                                    <ColumnDefinition Width="60" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{x:Bind Rank}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{x:Bind Name}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{x:Bind ListenCount}"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <!-- Top Albums -->
                                    <Border Background="{ThemeResource ContentDialogBackground}"
                                            Padding="8"
                                            CornerRadius="8"
                                            Width="300">
                                        <StackPanel>
                                            <TextBlock x:Uid="StatTopAlbums"
                                                       FontWeight="SemiBold"
                                                       FontSize="14" />
                                            <ScrollViewer Height="550"
                                                          VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{x:Bind StatisticsViewModel.TopAlbums, Mode=OneWay}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="statistics:RankedTopItem">
                                                            <Grid Margin="4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="32" />
                                                                    <ColumnDefinition Width="160" />
                                                                    <ColumnDefinition Width="60" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{x:Bind Rank}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{x:Bind Name}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="2"
                                                                           HorizontalAlignment="Right"
                                                                           Text="{x:Bind ListenCount}"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <!-- Top Tracks -->
                                    <Border Background="{ThemeResource ContentDialogBackground}"
                                            Padding="8"
                                            CornerRadius="8"
                                            Width="300">
                                        <StackPanel>
                                            <TextBlock x:Uid="StatTopSongs"
                                                       FontWeight="SemiBold"
                                                       FontSize="14" />
                                            <ScrollViewer Height="550"
                                                          VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{x:Bind StatisticsViewModel.TopTracks, Mode=OneWay}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="statistics:RankedTopItem">
                                                            <Grid Margin="4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="32" />
                                                                    <ColumnDefinition Width="160" />
                                                                    <ColumnDefinition Width="60" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{x:Bind Rank}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{x:Bind Name}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{x:Bind ListenCount}"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>


                                <!-- Charts -->
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12">

                                    <Border Background="{ThemeResource ContentDialogBackground}"
                                            Padding="8"
                                            CornerRadius="8"
                                            Width="300">
                                        <ScrollViewer Height="500"
                                                      VerticalScrollBarVisibility="Auto">
                                            <controls:PieChart x:Uid="StartTracksByFileType"
                                                               Items="{x:Bind StatisticsViewModel.Current.TracksByFileType, Mode=OneWay}" />
                                        </ScrollViewer>
                                    </Border>

                                    <Border Background="{ThemeResource ContentDialogBackground}"
                                            Padding="8"
                                            CornerRadius="8"
                                            Width="300">
                                        <ScrollViewer Height="500"
                                                      VerticalScrollBarVisibility="Auto">
                                            <controls:PieChart x:Uid="StartAlbumsByType"
                                                               Items="{x:Bind StatisticsViewModel.Current.AlbumsByType, Mode=OneWay}" />
                                        </ScrollViewer>
                                    </Border>

                                    <Border Background="{ThemeResource ContentDialogBackground}"
                                            Padding="8"
                                            CornerRadius="8"
                                            Width="300">
                                        <ScrollViewer Height="500"
                                                      VerticalScrollBarVisibility="Auto">
                                            <controls:PieChart x:Uid="StartArtistsByGenre"
                                                               Items="{x:Bind StatisticsViewModel.Current.ArtistsByGenre, Mode=OneWay}" />
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>

                            </StackPanel>

                        </ScrollViewer>
                    </Grid>
                </Border>
            </PivotItem>

            <PivotItem x:Uid="OptionTabAbout">
                <Border Background="{ThemeResource CardBackgroundFillColorDefault}"
                        Padding="4"
                        CornerRadius="12"
                        Margin="8">

                    <StackPanel Spacing="16"
                                Margin="24,18,24,18">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="1">

                            <TextBlock FontSize="22"
                                       FontWeight="Bold"
                                       Text="RoK music player"
                                       VerticalAlignment="Bottom"
                                       Foreground="{ThemeResource AccentAAFillColorTertiaryBrush}" />
                            <TextBlock FontSize="18"
                                       FontStyle="Italic"
                                       VerticalAlignment="Bottom"
                                       Text="v"
                                       Margin="6,0,0,0" />
                            <TextBlock FontSize="18"
                                       FontStyle="Italic"
                                       VerticalAlignment="Bottom"
                                       Text="{x:Bind AppVersionString}"
