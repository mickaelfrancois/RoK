                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <SymbolIcon Symbol="Globe"></SymbolIcon>
                                        <TextBlock Text="Source code on GitHub"></TextBlock>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <Button Click="OpenLogButton_Click">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <SymbolIcon Symbol="Document"></SymbolIcon>
