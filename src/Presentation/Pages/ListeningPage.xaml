<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Rok.Pages.ListeningPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Rok.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:common="using:Rok.Commons"
      xmlns:track="using:Rok.ViewModels.Track"
      Loaded="ListeningPage_Loaded"
      x:Name="PageRoot"
      mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" x:Name="playlistRow" />
            <RowDefinition MinHeight="{StaticResource SmallHeaderHeight}" MaxHeight="{StaticResource SmallHeaderHeight}" x:Name="headerRow" />
            <RowDefinition Height="auto" x:Name="commandRow" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.Background>
            <SolidColorBrush Color="{ThemeResource CardBackgroundFillColorDefault}" Opacity="{StaticResource HeaderBackgroundOpacity}" />
        </Grid.Background>

        <Image x:Name="backdrop" Grid.RowSpan="4" Source="{x:Bind ViewModel.Artist.Backdrop,Mode=OneWay}" Opacity="{StaticResource HeaderBackdropOpacity}" Style="{StaticResource HeaderBackdropStyle}" Stretch="UniformToFill" IsHitTestVisible="False" />

        <!-- Title -->
        <StackPanel Orientation="Horizontal" Margin="4,6,0,6">
            <SymbolIcon Symbol="MusicInfo" Margin="4,0,4,0" />
            <TextBlock x:Uid="ListeningViewTitle" x:Name="title" Style="{StaticResource HeaderStyle}" />
            <TextBlock Text="{x:Bind ViewModel.TrackCount}" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="{StaticResource FontSizeXMedium}" Margin="6,0,4,4" VerticalAlignment="Bottom" />
            <TextBlock x:Uid="ListeningViewTitleCount" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="{StaticResource FontSizeXMedium}" Margin="0,0,4,4" VerticalAlignment="Bottom" />
            <TextBlock Text="{x:Bind ViewModel.Duration, Converter={StaticResource LongToTimespanConverter}}" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="{StaticResource FontSizeXMedium}" Margin="0,0,4,4" VerticalAlignment="Bottom" />
        </StackPanel>

        <Line Stretch="Fill" Stroke="{StaticResource AppBarSeparatorForegroundThemeBrush}" VerticalAlignment="Bottom" X2="100"></Line>

        <!-- Header -->
        <Grid Grid.Row="1" Padding="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="pictureColumn" Width="100" />
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid Margin="6" Padding="0" CornerRadius="{StaticResource CornerRadiusMediumValue}">
                <common:PictureControl x:Name="artistPicture" Height="100" Width="100" Cover="{x:Bind ViewModel.Artist.Picture, Mode=OneWay}" UseArtistFallback="True" Style="{StaticResource HeaderPictureStyle}" />
                <common:AnimatedButton x:Uid="artistFavoriteButton"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Icon="{StaticResource HeartPath}"
                                       Color="{x:Bind ViewModel.Artist.IsFavorite, Converter={StaticResource FavoriteToColorConverter}, Mode=OneWay}"
                                       Command="{x:Bind ViewModel.Artist.ArtistFavoriteCommand}"
                                       CommandParameter="{x:Bind ViewModel.Artist.IsFavorite, Converter={StaticResource BoolToInvertBoolConverter}, Mode=OneWay}" />

                <Button x:Uid="selectPicture" Style="{StaticResource HeaderPictureSelectButtonStyle}" Command="{x:Bind ViewModel.Artist.SelectPictureCommand}" />
            </Grid>

            <RelativePanel Grid.Column="1" Margin="6,0,0,0">

                <HyperlinkButton x:Name="artistName" Content="{x:Bind ViewModel.CurrentTrack.ArtistName, Mode=OneWay}" Command="{x:Bind ViewModel.ArtistOpenCommand}" FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold" Padding="0" Margin="0" Style="{StaticResource HeaderHyperlinkStyle}" />

                <Button x:Name="buttonCountry" RelativePanel.RightOf="artistName" RelativePanel.AlignVerticalCenterWith="artistName" Margin="4,0,0,0" Style="{StaticResource ButtonTextBlockStyle}" Visibility="{x:Bind ViewModel.Artist.Artist.CountryCode, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" BorderBrush="Transparent" Background="Transparent" ToolTipService.ToolTip="{x:Bind ViewModel.Artist.Artist.CountryName, Mode=OneWay}">
                    <Image Source="{x:Bind ViewModel.Artist.Artist.CountryCode, Mode=OneWay, Converter={StaticResource CountryCodeToImageSourceConverter}}" Height="10"></Image>
                </Button>

                <TextBlock x:Name="year" RelativePanel.RightOf="buttonCountry" RelativePanel.AlignVerticalCenterWith="buttonCountry" Text="{x:Bind ViewModel.Artist.ActiveYears}" Style="{StaticResource SubtitleTextBlockStyle}" FontSize="{StaticResource FontSizeSmall}" Margin="10,-1,0,0" VerticalAlignment="Center" />
                <HyperlinkButton x:Name="genreName" Content="{x:Bind ViewModel.Artist.Artist.GenreName}" RelativePanel.Below="artistName" Command="{x:Bind ViewModel.Artist.GenreOpenCommand}" Style="{StaticResource HeaderHyperlinkStyle}" />
                <CommandBar x:Name="panelNetwork" RelativePanel.Below="genreName" Style="{StaticResource HeaderCommandBarStyle}">
                    <common:SocialNetworkAppBarButton x:Uid="artistViewWebSite" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="{x:Bind ViewModel.Artist.Artist.OfficialSiteUrl, Mode=OneWay}" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.OfficialSiteUrl, Mode=OneWay}" IconFill="{StaticResource WebsiteBrush}" IconData="{StaticResource BrandIconWebsite}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewLastFm" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Last.FM" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.LastFmUrl, Mode=OneWay}" IconFill="{StaticResource LastFmBrush}" IconData="{StaticResource BrandIconLastFm}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewWikipedia" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Wikipedia" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.WikipediaUrl, Mode=OneWay}" IconFill="{StaticResource WikipediaBrush}" IconData="{StaticResource BrandIconWikipedia}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewFacebook" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Facebook" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.FacebookUrl, Mode=OneWay}" IconFill="{StaticResource FacebookBrush}" IconData="{StaticResource BrandIconFacebook}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewInstagram" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Instagram" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.InstagramUrl, Mode=OneWay}" IconFill="{StaticResource InstagramBrush}" IconData="{StaticResource BrandIconInstagram}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewTwitter" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="X" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.TwitterUrl, Mode=OneWay}" IconFill="{StaticResource TwitterBrush}" IconData="{StaticResource BrandIconTwitter}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewThreads" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Threads" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.ThreadsUrl, Mode=OneWay}" IconFill="{StaticResource ThreadsBrush}" IconData="{StaticResource BrandIconThreads}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewTikTok" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Tiktok" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.TiktokUrl, Mode=OneWay}" IconFill="{StaticResource TiktokBrush}" IconData="{StaticResource BrandIconTikTok}" />
                    <common:SocialNetworkAppBarButton x:Uid="artistViewYoutube" Style="{StaticResource HeaderBrandButtonStyle}" ToolTipService.ToolTip="Youtube" Command="{x:Bind ViewModel.Artist.OpenUrlCommand, Mode=OneWay}" Url="{x:Bind ViewModel.Artist.Artist.YoutubeUrl, Mode=OneWay}" IconFill="{StaticResource YoutubeBrush}" IconData="{StaticResource BrandIconYoutube}" />
                </CommandBar>
            </RelativePanel>
        </Grid>

        <!-- Commands -->
        <RelativePanel Grid.Row="2" Margin="6,0,0,0">
            <CommandBar RelativePanel.AlignBottomWithPanel="True" Style="{StaticResource HeaderCommandBarStyle}">
                <AppBarButton x:Uid="shuffleButton" Style="{StaticResource AppBarButtonCompactStyle}" Icon="Shuffle" Command="{x:Bind ViewModel.ShufflePlaylistCommand}" />

                <AppBarButton x:Uid="playerSleepModeAppBarButton" Style="{StaticResource AppBarButtonCompactStyle}" Icon="Clock">
                    <AppBarButton.Flyout>
                        <MenuFlyout Placement="Top" Opening="SleepFlyout_Opening">
                            <MenuFlyoutItem IsEnabled="False" Text="{x:Bind ViewModel.RemainingSleepTime, Mode=OneWay, Converter={StaticResource SecondsToReadableConverter}}" Visibility="{x:Bind ViewModel.IsSleepModeActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <MenuFlyoutItem x:Uid="playerSleepOff" Command="{x:Bind ViewModel.StopSleepTimerCommand}" Visibility="{x:Bind ViewModel.IsSleepModeActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Cancel" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator Visibility="{x:Bind ViewModel.IsSleepModeActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <MenuFlyoutItem x:Uid="playerSleep5" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer5}" />
                            <MenuFlyoutItem x:Uid="playerSleep10" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer10}" />
                            <MenuFlyoutItem x:Uid="playerSleep15" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer15}" />
                            <MenuFlyoutItem x:Uid="playerSleep30" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer30}" />
                            <MenuFlyoutItem x:Uid="playerSleep45" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer45}" />
                            <MenuFlyoutItem x:Uid="playerSleep60" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer60}" />
                        </MenuFlyout>
                    </AppBarButton.Flyout>
                </AppBarButton>
            </CommandBar>
        </RelativePanel>

        <!-- Tracks -->
        <Grid x:Name="tracks" CornerRadius="12,12,0,0" Padding="24" Background="{ThemeResource CardBackgroundFillColorDefault}" Margin="4,0,4,4" Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource GridHeaderTracksHeight}" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid Style="{StaticResource HeaderTracksGridStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource GridHeaderTracksTitleColumnWidth}" />
                    <ColumnDefinition Width="{StaticResource GridHeaderTracksArtistColumnWidth}" />
                    <ColumnDefinition Width="{StaticResource GridHeaderTracksAlbumColumnWidth}" />
                    <ColumnDefinition Width="{StaticResource GridHeaderTracksGenreColumnWidth}" />
                    <ColumnDefinition Width="{StaticResource GridHeaderTracksScoreColumnWidth}" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Uid="gridHeaderTitle" Grid.Column="0" Style="{StaticResource GridHeaderTracksTextBlockStyle}" />
                <TextBlock x:Uid="gridHeaderArtist" Grid.Column="1" Style="{StaticResource GridHeaderTracksTextBlockStyle}" />
                <TextBlock x:Uid="gridHeaderAlbum" Grid.Column="2" Style="{StaticResource GridHeaderTracksTextBlockStyle}" />
                <TextBlock x:Uid="gridHeaderGenre" Grid.Column="3" Style="{StaticResource GridHeaderTracksTextBlockStyle}" />
                <TextBlock x:Uid="gridHeaderScore" Grid.Column="4" Style="{StaticResource GridHeaderTracksTextBlockStyle}" />
            </Grid>

            <common:ListViewExtended x:Name="tracksList" ItemsSource="{x:Bind ViewModel.Tracks}" ContainerContentChanging="tracksList_ContainerContentChanging" Grid.Row="1" BorderThickness="0" ItemContainerStyle="{StaticResource TracksListViewItemStyle}" Margin="0" >
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="track:TrackViewModel">
                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" Margin="0,0,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{StaticResource GridHeaderTracksTitleColumnWidth}" />
                                <ColumnDefinition Width="{StaticResource GridHeaderTracksArtistColumnWidth}" />
                                <ColumnDefinition Width="{StaticResource GridHeaderTracksAlbumColumnWidth}" />
                                <ColumnDefinition Width="{StaticResource GridHeaderTracksGenreColumnWidth}" />
                                <ColumnDefinition Width="{StaticResource GridHeaderTracksScoreColumnWidth}" />
                            </Grid.ColumnDefinitions>

                            <Grid.ContextFlyout>
                                <MenuFlyout ShowMode="TransientWithDismissOnPointerMoveAway" common:MenuFlyoutExtensions.PlaylistMenuService="{x:Bind PlaylistMenuService}" common:MenuFlyoutExtensions.TrackId="{x:Bind Track.Id}">
                                    <MenuFlyoutItem x:Uid="trackFlyoutAddMoreFromArtist" Command="{Binding ElementName=PageRoot, Path=ViewModel.AddMoreFromArtistCommand}" CommandParameter="{x:Bind}" IsEnabled="{x:Bind Track.ArtistId.HasValue}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE725;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:Uid="trackFlyoutArtist" Icon="People" Command="{x:Bind ArtistOpenCommand}" />
                                    <MenuFlyoutItem x:Uid="trackFlyoutAlbum" Command="{x:Bind AlbumOpenCommand}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE93C;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:Uid="trackFlyoutTrack" Icon="Audio" Command="{x:Bind TrackOpenCommand}" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Uid="trackFlyoutLyrics" Command="{x:Bind LyricsOpenCommand}" Visibility="{x:Bind LyricsExists, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE90B;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>

                            <!-- Listening -->
                            <Grid VerticalAlignment="Center">

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Margin="0,0,2,0" HorizontalAlignment="Left" VerticalAlignment="Center" Stretch="None" Visibility="{x:Bind Listening, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Image.Source>
                                            <BitmapImage AutoPlay="True" DecodePixelWidth="24" DecodePixelHeight="24" UriSource="ms-appx:///Assets/equalizer.gif" />
                                        </Image.Source>
                                    </Image>
                                    <TextBlock x:Name="RowIndexText" VerticalAlignment="Center" Visibility="{x:Bind Listening, Mode=OneWay, Converter={StaticResource BoolToInvertVisibilityConverter}}" Style="{StaticResource gridTracksRowIndexText}" />

                                    <HyperlinkButton Style="{StaticResource GridTracksTitleHyperlinkButtonStyle}" Command="{x:Bind TrackOpenCommand}" CommandParameter="{x:Bind}" VerticalAlignment="Center" />
                                    <HyperlinkButton Visibility="{x:Bind LyricsType, Converter={StaticResource LyricsTypeVisibilityConverter}, ConverterParameter=Synchronized, Mode=OneWay}" Style="{StaticResource GridTracksSyncLyricsBadgeStyle}" Command="{x:Bind LyricsOpenCommand}" />
                                    <HyperlinkButton Visibility="{x:Bind LyricsType, Converter={StaticResource LyricsTypeVisibilityConverter}, ConverterParameter=Plain, Mode=OneWay}" Style="{StaticResource GridTracksPlainLyricsBadgeStyle}" Command="{x:Bind LyricsOpenCommand}" />
                                </StackPanel>
                            </Grid>

                            <HyperlinkButton Grid.Column="1" Style="{StaticResource GridTracksArtistHyperlinkButtonStyle}" Command="{x:Bind ArtistOpenCommand}" />
                            <HyperlinkButton Grid.Column="2" Style="{StaticResource GridTracksAlbumHyperlinkButtonStyle}" Command="{x:Bind AlbumOpenCommand}" />
                            <HyperlinkButton Grid.Column="3" Style="{StaticResource GridTracksGenreHyperlinkButtonStyle}" Command="{x:Bind GenreOpenCommand}" />
                            <common:RatingControlLightControl Grid.Column="4" Style="{StaticResource GridTracksScoreStyle}" RatingValue="{x:Bind Score, Mode=TwoWay}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </common:ListViewExtended>
        </Grid>
    </Grid>
</Page>
