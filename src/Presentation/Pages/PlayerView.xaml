<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="Rok.Pages.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Rok.Pages"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:commons="using:Rok.Commons"
             xmlns:converters="using:Rok.Converters"
             xmlns:controls="using:Rok.Commons"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:FloatToStringConverter x:Key="FloatToStringConverter" />



        <Style x:Key="MiniLinkStyle" TargetType="HyperlinkButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{ThemeResource OnSurfacePrimaryBrush}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="HyperlinkButton">
                        <Grid x:Name="RootGrid" Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" To="0.75" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" Padding="{TemplateBinding Padding}" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="EllipsisTemplate">
            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
        </DataTemplate>

        <Style x:Key="PlayPauseButtonStyle" TargetType="AppBarButton">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#33000000" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="AppBarButton">
                        <Grid x:Name="Root" Background="Transparent">
                            <Border x:Name="Circle"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="1000"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="ScaleT" ScaleX="1" ScaleY="1" />
                                    </Grid.RenderTransform>
                                    <ContentPresenter x:Name="IconPresenter"
                                                      Content="{TemplateBinding Icon}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Foreground="{TemplateBinding Foreground}" />
                                    <TextBlock x:Name="LabelText"
                                               Text="{TemplateBinding Label}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="10"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,4"
                                               Opacity="0"
                                               IsHitTestVisible="False" />
                                </Grid>
                            </Border>
                            <Border x:Name="FocusRing"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    CornerRadius="1000"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    Opacity="0"
                                    IsHitTestVisible="False" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Circle" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ButtonBackgroundPointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Circle" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ButtonBackgroundPressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetName="ScaleT" Storyboard.TargetProperty="ScaleX" To="0.90" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleT" Storyboard.TargetProperty="ScaleY" To="0.90" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0:0:0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="FocusRing" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerFocused" />
                                    <VisualState x:Name="Unfocused" />
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="DisplayModeStates">
                                    <VisualState x:Name="Compact" />
                                    <VisualState x:Name="FullSize">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="LabelText" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid x:Name="mainGrid" HorizontalAlignment="Stretch" Padding="4,4,4,4" ColumnSpacing="12" Background="{ThemeResource BrandPrimaryBrush}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="currentTrack.Visibility" Value="Visible" />
                        <Setter Target="currentTrack.Width" Value="500" />
                        <Setter Target="currentTrack.HorizontalAlignment" Value="Left" />
                        <Setter Target="radioPanel.Width" Value="500" />
                        <Setter Target="playerControls.Width" Value="350" />
                        <Setter Target="playerControls.HorizontalAlignment" Value="Center" />
                        <Setter Target="playerCommands.Width" Value="300" />
                        <Setter Target="playerCommands.Visibility" Value="Visible" />
                        <Setter Target="trackColumn.Width" Value="430" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="MediumLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="currentTrack.Visibility" Value="Visible" />
                        <Setter Target="currentTrack.Width" Value="350" />
                        <Setter Target="currentTrack.HorizontalAlignment" Value="Left" />
                        <Setter Target="radioPanel.Width" Value="350" />
                        <Setter Target="playerControls.Width" Value="300" />
                        <Setter Target="playerControls.HorizontalAlignment" Value="Center" />
                        <Setter Target="playerCommands.Width" Value="200" />
                        <Setter Target="playerCommands.Visibility" Value="Visible" />
                        <Setter Target="trackScore.Visibility" Value="Collapsed" />
                        <Setter Target="trackColumn.Width" Value="280" />
                        <Setter Target="trackProgression.Width" Value="300" />
                        <Setter Target="progressSlider.Width" Value="180" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="NarrowLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="500" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="currentTrack.Visibility" Value="Visible" />
                        <Setter Target="currentTrack.Width" Value="250" />
                        <Setter Target="currentTrack.HorizontalAlignment" Value="Left" />
                        <Setter Target="radioPanel.Width" Value="250" />
                        <Setter Target="playerControls.Width" Value="250" />
                        <Setter Target="playerControls.HorizontalAlignment" Value="Center" />
                        <Setter Target="playerCommands.Visibility" Value="Collapsed" />
                        <Setter Target="trackScore.Visibility" Value="Collapsed" />
                        <Setter Target="trackColumn.Width" Value="180" />
                        <Setter Target="trackProgression.Width" Value="250" />
                        <Setter Target="progressSlider.Width" Value="130" />
                        <Setter Target="trackTitle.MaxWidth" Value="150" />
                        <Setter Target="trackArtist.MaxWidth" Value="100" />
                        <Setter Target="trackAlbum.MaxWidth" Value="100" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="MinimalLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="currentTrack.Visibility" Value="Collapsed" />
                        <Setter Target="radioPanel.Visibility" Value="Collapsed" />
                        <Setter Target="playerControls.Width" Value="Auto" />
                        <Setter Target="playerControls.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="playerControls.Margin" Value="0" />
                        <Setter Target="playerCommands.Visibility" Value="Collapsed" />
                        <Setter Target="trackProgression.Width" Value="Auto" />
                        <Setter Target="trackProgression.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="progressSlider.Width" Value="Auto" />
                        <Setter Target="progressSlider.HorizontalAlignment" Value="Stretch" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid Translation="0,0,10">
            <Grid.Shadow>
                <ThemeShadow />
            </Grid.Shadow>
        </Grid>

        <!-- Current track info -->
        <Grid x:Name="currentTrack"
              Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="visualChangeGroup">
                    <VisualState x:Name="changeTrackTitleAnimation">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="trackTitle" From="0" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:2" />
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="changeTrackScoreAnimation">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="trackScore" From="0" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:2" />
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="changeTrackArtistAnimation">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="trackArtist" From="0" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:2" />
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="changeTrackAlbumAnimation">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="trackAlbum" From="0" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:2" />
                            <DoubleAnimation Storyboard.TargetName="currentTrackCover" From="0" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:2" />
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" x:Name="coverColumn"></ColumnDefinition>
                <ColumnDefinition x:Name="trackColumn"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Border x:Name="currentTrackCover" Grid.Column="0" CornerRadius="4" Padding="1" Width="70" Height="70" BorderThickness="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid CornerRadius="4" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <Image Width="70" Height="70" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{x:Bind ViewModel.CurrentAlbum.Picture, Mode=OneWay}">
                        <Image.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition />
                            </TransitionCollection>
                        </Image.Transitions>
                    </Image>
                </Grid>
            </Border>

            <Grid x:Name="currentTrackInfo" Grid.Column="1" HorizontalAlignment="Stretch" Height="70">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"></RowDefinition>
                    <RowDefinition Height="35"></RowDefinition>
                </Grid.RowDefinitions>

                <!--Title line-->
                <StackPanel x:Name="trackTitleLine" Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Margin="6,0,0,0">
                    <HyperlinkButton Grid.Column="0" x:Name="trackTitle" HorizontalAlignment="Left" HorizontalContentAlignment="Left" MinWidth="100" MaxWidth="200" Style="{StaticResource MiniLinkStyle}" Command="{x:Bind ViewModel.CurrentTrack.TrackOpenCommand, Mode=OneWay}" Content="{x:Bind ViewModel.CurrentTrack.Title, Mode=OneWay, FallbackValue=''}" ContentTemplate="{StaticResource EllipsisTemplate}" ToolTipService.ToolTip="{x:Bind ViewModel.CurrentTrack.Title, Mode=OneWay, FallbackValue=''}" Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <commons:RatingControlDarkControl x:Name="trackScore" Margin="30,0,0,0" HorizontalAlignment="Right" InitialValue="{x:Bind ViewModel.CurrentTrack.Score, Mode=OneWay}" Value="{x:Bind ViewModel.CurrentTrack.Score, Mode=TwoWay}" Width="150" VerticalAlignment="Center" Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    </commons:RatingControlDarkControl>
                </StackPanel>

                <!--Track info line-->
                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="6,0,0,0">
                    <HyperlinkButton Style="{StaticResource MiniLinkStyle}" x:Name="trackArtist" MaxWidth="200" Command="{x:Bind ViewModel.CurrentTrack.ArtistOpenCommand, Mode=OneWay}" Content="{x:Bind ViewModel.CurrentTrack.ArtistName, Mode=OneWay, FallbackValue=''}" ContentTemplate="{StaticResource EllipsisTemplate}" ToolTipService.ToolTip="{x:Bind ViewModel.CurrentTrack.ArtistName, Mode=OneWay, FallbackValue=''}" Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="•" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="6,0,6,0" Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <HyperlinkButton Style="{StaticResource MiniLinkStyle}" x:Name="trackAlbum" MaxWidth="200" Command="{x:Bind ViewModel.CurrentTrack.AlbumOpenCommand, Mode=OneWay}" Content="{x:Bind ViewModel.CurrentTrack.AlbumName, Mode=OneWay, FallbackValue=''}" ContentTemplate="{StaticResource EllipsisTemplate}" ToolTipService.ToolTip="{x:Bind ViewModel.CurrentTrack.AlbumName, Mode=OneWay, FallbackValue=''}" Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Grid>


        <!-- Player controls -->
        <Grid x:Name="playerControls">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>


            <!--Current track progression-->
            <Grid x:Name="trackProgression" VerticalAlignment="Center" Grid.Row="1" Margin="0" Padding="0" Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="60"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.ListenDurationStr, Mode=OneWay}" Foreground="White" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="14" Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Slider x:Name="progressSlider" Grid.Column="1" Margin="0,2,0,0" VerticalAlignment="Center" HorizontalAlignment="Stretch" Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Value="{x:Bind ViewModel.ListenDuration, Mode=OneWay, Converter={StaticResource TimeSpanToDoubleConverter}}" Maximum="{x:Bind ViewModel.DurationTotal, Mode=OneWay, Converter={StaticResource TimeSpanToDoubleConverter}}" ThumbToolTipValueConverter="{StaticResource DoubleToTimespanConverter}" IsThumbToolTipEnabled="True" LargeChange="7" SmallChange="5" PointerCaptureLost="Slider_PointerCaptureLost" ManipulationStarted="Slider_ManipulationStarted" ManipulationMode="All" />
                <ProgressBar Grid.Column="1" Margin="0,2,0,0" VerticalAlignment="Center" HorizontalAlignment="Stretch" Height="2" IsIndeterminate="True" Foreground="{ThemeResource BadgeLiveBrush}" Background="Transparent" Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.DurationTotalStr, Mode=OneWay}" Foreground="White" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>


            <!-- Player commands -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <AppBarButton Icon="Previous" Command="{x:Bind ViewModel.SkipPreviousCommand}" IsEnabled="{x:Bind ViewModel.CanSkipPrevious, Mode=OneWay}" Foreground="White" RequestedTheme="Dark" VerticalAlignment="Center" Width="40" Margin="0" />
                <Grid VerticalAlignment="Center" Margin="10,0,0,0">
                    <Border x:Name="sleepModeHalo"
                            Width="48"
                            Height="48"
                            CornerRadius="24"
                            Background="White"
                            Opacity="0"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    <AppBarButton x:Name="playPauseButton" Command="{x:Bind ViewModel.TogglePlayPauseCommand}" Foreground="White" Margin="0" RequestedTheme="Dark" Style="{StaticResource PlayPauseButtonStyle}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <SymbolIcon Symbol="{x:Bind ViewModel.PlaybackState, Mode=OneWay, Converter={StaticResource PlaybackStateToButtonIconConverter}}" />
                    </AppBarButton>
                </Grid>
                <AppBarButton Icon="Next" Command="{x:Bind ViewModel.SkipNextCommand}" IsEnabled="{x:Bind ViewModel.CanSkipNext, Mode=OneWay}" Foreground="White" RequestedTheme="Dark" VerticalAlignment="Center" Width="40" Margin="10,0,0,0" />
            </StackPanel>
        </Grid>


        <!-- Player extra commands -->
        <Grid x:Name="playerCommands" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0">
            <CommandBar HorizontalAlignment="Right" Background="Transparent" DefaultLabelPosition="Collapsed" RequestedTheme="Dark">
                <AppBarButton Icon="MusicInfo" Command="{x:Bind ViewModel.OpenListeningCommand}" Foreground="White"
                              Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ToolTipService.ToolTip>
                        <TextBlock x:Uid="PlayerCurrentListeningToolTips" Text="Show current playlist" />
                    </ToolTipService.ToolTip>
                </AppBarButton>

                <AppBarButton x:Name="volume" Foreground="White">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="{x:Bind ViewModel.Volume, Mode=OneWay, Converter={StaticResource VolumeToGlyphConverter}}" />
                    <AppBarButton.Flyout>
                        <Flyout>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Margin="0,0,4,0" Command="{x:Bind ViewModel.MuteCommand}" Background="Transparent">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="{x:Bind ViewModel.Volume, Mode=OneWay, Converter={StaticResource VolumeToGlyphConverter}}" />
                                </Button>
                                <Slider Width="200" Value="{x:Bind ViewModel.Volume, Mode=TwoWay}" Minimum="0" Maximum="100"></Slider>
                            </StackPanel>
                        </Flyout>
                    </AppBarButton.Flyout>
                </AppBarButton>

                <CommandBar.SecondaryCommands>
                    <AppBarButton x:Uid="playerEqualizerAppBarButton" x:Name="btEqualizer" Command="{x:Bind ViewModel.ToggleEqualizerCommand}">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE9E9;" FontSize="16" />
                        </AppBarButton.Icon>
                    </AppBarButton>

                    <AppBarButton x:Uid="playerCompactModeAppBarButton" x:Name="btCompactMode" Command="{x:Bind ViewModel.CompactModeCommand}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="StopSlideShow" />
                        </AppBarButton.Icon>
                    </AppBarButton>

                    <AppBarButton x:Uid="playerFullscreenAppBarButton" Command="{x:Bind ViewModel.FullscreenCommand}"
                                  Visibility="{x:Bind ViewModel.IsMusicMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="FullScreen" />
                        </AppBarButton.Icon>
                    </AppBarButton>

                    <AppBarButton x:Uid="playerSleepModeAppBarButton">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Clock"/>
                        </AppBarButton.Icon>

                        <AppBarButton.Flyout>
                            <MenuFlyout Placement="Top" Opening="SleepFlyout_Opening">
                                <MenuFlyoutItem IsEnabled="False" Text="{x:Bind ViewModel.RemainingSleepTime, Mode=OneWay, Converter={StaticResource SecondsToReadableConverter}}" Visibility="{x:Bind ViewModel.IsSleepModeActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <MenuFlyoutItem Text="Off" Command="{x:Bind ViewModel.StopSleepTimerCommand}" Visibility="{x:Bind ViewModel.IsSleepModeActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Cancel" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator Visibility="{x:Bind ViewModel.IsSleepModeActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <MenuFlyoutItem Text="5 minutes" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer5}" />
                                <MenuFlyoutItem Text="10 minutes" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer10}" />
                                <MenuFlyoutItem Text="15 minutes" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer15}" />
                                <MenuFlyoutItem Text="30 minutes" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer30}" />
                                <MenuFlyoutItem Text="45 minutes" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer45}" />
                                <MenuFlyoutItem Text="60 minutes" Command="{x:Bind ViewModel.SetSleepTimerCommand}" CommandParameter="{StaticResource SleepTimer60}" />
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                </CommandBar.SecondaryCommands>
            </CommandBar>
        </Grid>

        <!-- Radio mode panel — takes the same slot as currentTrack so player controls remain visible.
             Width is driven by the same VisualStates as currentTrack. -->
        <Grid x:Name="radioPanel"
              Visibility="{x:Bind ViewModel.IsRadioMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
              HorizontalAlignment="Left" VerticalAlignment="Center"
              ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" CornerRadius="4" Width="70" Height="70"
                    Background="{ThemeResource BadgeLiveBrush}">
                <Grid>
                    <FontIcon Glyph="&#xE8D6;" FontFamily="Segoe Fluent Icons"
                              FontSize="32" Foreground="White"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Image Source="{x:Bind ViewModel.CurrentStationFaviconUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                           Stretch="UniformToFill" />
                </Grid>
            </Border>
            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Spacing="2" Margin="6,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Background="{ThemeResource BadgeLiveBrush}" CornerRadius="4" Padding="6,1">
                        <TextBlock Text="LIVE" Foreground="White" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <TextBlock x:Uid="playerBuffering" FontSize="11" Foreground="White" Opacity="0.7"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.CurrentStationName, Mode=OneWay, TargetNullValue=''}"
                           FontSize="14" FontWeight="SemiBold" Foreground="White"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{x:Bind ViewModel.CurrentStreamTitle, Mode=OneWay, TargetNullValue=''}"
                           FontSize="12" Foreground="White" Opacity="0.8"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{x:Bind ViewModel.CurrentStreamTitle, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>