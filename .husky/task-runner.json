{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
	"tasks": [
		{
			"name": "dotnet-build",
			"group": "pre-commit-operations",
			"command": "dotnet",
			"args": [ "build", "--no-restore", "-v", "quiet", "/p:Platform=x64" ]
		},
		{
			"name": "dotnet-format-staged-files",
			"group": "pre-commit-operations",
			"command": "dotnet",
			"args": [ "format", "--include", "${staged}", "/p:Platform=x64" ],
			"include": [ "**/*.cs" ]
		},
		{
			"name": "dotnet-test",
			"group": "pre-push-operations",
			"command": "dotnet",
			"args": [ "test", "--no-build", "/p:Platform=x64" ]
		}
	]
}
